---
// Main Banner component for the homepage
---

<div class="banner-container">
  <!-- Provide fallback or reference to the user's banner.webp / banner.jpg -->
  <img 
    src={`${import.meta.env.BASE_URL}/banner_ejemplo.jpg`} 
    alt="Deco de fibras naturales - Bibi's" 
    class="banner-img" 
    loading="lazy"
  />
</div>

<style>
  .banner-container {
    width: 100%;
    margin: 0;
    padding: 0;
    overflow: hidden;
    position: relative;
    /* Un pequeño subtrazo o top stroke si fuera necesario */
  }

  .banner-img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
    max-height: 480px; 
  }

  @media screen and (max-width: 768px) {
    .banner-img {
      min-height: 200px;
    }
  }
</style>
