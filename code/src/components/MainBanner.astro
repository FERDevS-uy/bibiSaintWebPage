---
// Main Banner component for the homepage
import { withBasePath } from "@utils/basePath";

const bannerSrc = withBasePath("/banner.jpeg", Astro.url.pathname);
---

<div class="banner-container">
  <!-- Provide fallback or reference to the user's banner.webp / banner.jpg -->
  <img 
    src={bannerSrc} 
    alt="Deco de fibras naturales - Bibi's" 
    class="banner-img" 
    loading="lazy"
  />
</div>

<style>
  .banner-container {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-top: 0;
    margin-bottom: 0;
    padding: 0;
    overflow: hidden;
    position: relative;
    /* Un pequeño subtrazo o top stroke si fuera necesario */
  }

  .banner-img {
    width: 100%;
    height: auto;
    margin: 0;
    max-width: none;
    object-fit: cover;
    display: block;
    max-height: none;
  }

  @media screen and (max-width: 768px) {
    .banner-img {
      min-height: 200px;
    }
  }
</style>
