---
const rawBaseUrl = import.meta.env.BASE_URL || "/";
const normalizedBaseUrl = rawBaseUrl === "/"
  ? ""
  : rawBaseUrl.replace(/\/$/, "");

const ofertasHref = `${normalizedBaseUrl}/ofertas`;
const bannerSrc = `${normalizedBaseUrl}/banner.jpeg`;
---

<section id="banner" aria-label="Banner de ofertas destacadas">
  <a class="hero-link" href={ofertasHref}>
    <picture class="hero-media">
      <img
        src={bannerSrc}
        alt="Ofertas destacadas de Bibi's"
        loading="lazy"
        class="hero-image"
      />
    </picture>

    <div class="hero-overlay"></div>

    <div class="hero-content">
      <span class="hero-pill">Top precios</span>
      <h1>Ofertas para renovar tu casa</h1>
      <p>Encontrá los productos más convenientes en un solo lugar.</p>
      <span class="hero-cta">Descubrir ofertas</span>
    </div>
  </a>
</section>

<style>
  #banner {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-bottom: 2.8rem;
  }

  .hero-link {
    text-decoration: none;
    color: inherit;
    position: relative;
    display: block;
    isolation: isolate;
    overflow: hidden;
    background: #2d1f18;
  }

  .hero-media {
    display: block;
    width: 100%;
    position: relative;
  }

  .hero-image {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
    transform: none;
    transition: filter 0.2s ease;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(97deg, rgba(14, 10, 7, 0.83) 0%, rgba(14, 10, 7, 0.5) 35%, rgba(14, 10, 7, 0.2) 62%, rgba(14, 10, 7, 0.14) 100%),
      linear-gradient(180deg, rgba(14, 10, 7, 0.05) 0%, rgba(14, 10, 7, 0.4) 100%);
    z-index: 1;
  }

  .hero-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    max-width: 680px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: 0.62rem;
    padding: clamp(0.9rem, 2.2vw, 1.55rem);
    text-wrap: pretty;
    margin-inline: auto;
  }

  .hero-pill {
    width: fit-content;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffe8c4;
    font-weight: 800;
    padding: 0.25rem 0.62rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 224, 178, 0.4);
    background: rgba(74, 49, 34, 0.45);
    backdrop-filter: blur(2px);
  }

  .hero-content h1 {
    margin: 0;
    color: #fff6e7;
    text-shadow: 0 5px 14px rgba(0, 0, 0, 0.35);
    font-size: clamp(1.25rem, 3vw, 2.35rem);
    line-height: 1.08;
    font-weight: 800;
    max-width: 14ch;
    overflow-wrap: anywhere;
  }

  .hero-content p {
    margin: 0;
    color: #f2dfc7;
    max-width: 34ch;
    line-height: 1.33;
    font-size: clamp(0.78rem, 0.9vw, 0.92rem);
    text-shadow: 0 3px 10px rgba(0, 0, 0, 0.35);
    overflow-wrap: anywhere;
  }

  .hero-cta {
    margin-top: 0.32rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.56rem 1.08rem;
    border: 1px solid rgba(254, 239, 213, 0.75);
    color: #1f130c;
    background: linear-gradient(135deg, #ffe4b8 0%, #ffcc8f 100%);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    box-shadow: 0 8px 14px rgba(0, 0, 0, 0.24);
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .hero-link:hover .hero-image {
    filter: brightness(1.03);
  }

  .hero-link:hover .hero-cta {
    transform: translateY(-2px);
    filter: brightness(1.04);
  }

  @media screen and (max-width: 900px) {
    .hero-overlay {
      display: none;
    }

    .hero-content {
      position: static;
      max-width: none;
      width: 100%;
      gap: 0.66rem;
      padding: 0.9rem 0.82rem 1rem;
      background: linear-gradient(180deg, #2a1d15 0%, #1f140f 100%);
      align-items: center;
      text-align: center;
    }

    .hero-content h1 {
      font-size: clamp(1.08rem, 4.4vw, 1.58rem);
      max-width: 100%;
      line-height: 1.13;
    }

    .hero-content p {
      max-width: 100%;
      font-size: 0.8rem;
    }

    .hero-pill {
      font-size: 0.56rem;
      padding: 0.22rem 0.54rem;
    }

    .hero-cta {
      font-size: 0.72rem;
      padding: 0.5rem 0.95rem;
    }
  }

  @media screen and (max-width: 720px) {
    .hero-content {
      padding: 0.78rem 0.72rem 0.88rem;
    }

    .hero-content h1 {
      font-size: clamp(0.98rem, 5.7vw, 1.26rem);
    }

    .hero-content p {
      font-size: 0.74rem;
      line-height: 1.3;
    }

    .hero-pill {
      font-size: 0.52rem;
      padding: 0.2rem 0.5rem;
    }

    .hero-cta {
      width: 100%;
      justify-content: center;
      font-size: 0.69rem;
      padding: 0.48rem 0.88rem;
    }
  }
</style>
