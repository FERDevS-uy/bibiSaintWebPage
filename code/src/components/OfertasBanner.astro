---
---

<section id="banner" aria-label="Banner de ofertas destacadas">
  <a class="hero-link" href={`${import.meta.env.BASE_URL}/categories`}>
    <picture class="hero-media">
      <source srcset={`${import.meta.env.BASE_URL}/ofertas-panorama.svg`} type="image/svg+xml" />
      <img
        src={`${import.meta.env.BASE_URL}/banner.jpeg`}
        alt="Ofertas destacadas de Bibi's"
        loading="lazy"
        class="hero-image"
      />
    </picture>

    <div class="hero-overlay"></div>

    <div class="hero-content">
      <span class="hero-pill">Promociones de temporada</span>
      <h1>Tu casa pide cambio. Tus ofertas ya llegaron.</h1>
      <p>
        Diseno artesanal, texturas nobles y precios irresistibles para que
        renueves tus espacios con personalidad.
      </p>
      <span class="hero-cta">Descubrir ofertas</span>
    </div>
  </a>
</section>

<style>
  #banner {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-bottom: 2.8rem;
  }

  .hero-link {
    text-decoration: none;
    color: inherit;
    position: relative;
    display: block;
    isolation: isolate;
    min-height: clamp(350px, 64vw, 620px);
    overflow: clip;
    background: #2d1f18;
  }

  .hero-media {
    display: block;
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.01);
    transition: transform 0.7s ease;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(97deg, rgba(14, 10, 7, 0.83) 0%, rgba(14, 10, 7, 0.5) 35%, rgba(14, 10, 7, 0.2) 62%, rgba(14, 10, 7, 0.14) 100%),
      linear-gradient(180deg, rgba(14, 10, 7, 0.05) 0%, rgba(14, 10, 7, 0.4) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 760px;
    min-height: clamp(350px, 64vw, 620px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 1rem;
    padding: clamp(1.2rem, 3.2vw, 2.6rem);
    text-wrap: pretty;
  }

  .hero-pill {
    width: fit-content;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #ffe8c4;
    font-weight: 800;
    padding: 0.36rem 0.78rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 224, 178, 0.4);
    background: rgba(74, 49, 34, 0.45);
    backdrop-filter: blur(2px);
  }

  .hero-content h1 {
    margin: 0;
    color: #fff6e7;
    text-shadow: 0 6px 18px rgba(0, 0, 0, 0.35);
    font-size: clamp(1.9rem, 4.8vw, 4rem);
    line-height: 1.03;
    font-weight: 800;
    max-width: 18ch;
  }

  .hero-content p {
    margin: 0;
    color: #f2dfc7;
    max-width: 54ch;
    line-height: 1.48;
    font-size: clamp(0.95rem, 1.35vw, 1.2rem);
    text-shadow: 0 3px 10px rgba(0, 0, 0, 0.35);
  }

  .hero-cta {
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.8rem 1.35rem;
    border: 1px solid rgba(254, 239, 213, 0.75);
    color: #1f130c;
    background: linear-gradient(135deg, #ffe4b8 0%, #ffcc8f 100%);
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    box-shadow: 0 10px 18px rgba(0, 0, 0, 0.25);
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .hero-link:hover .hero-image {
    transform: scale(1.04);
  }

  .hero-link:hover .hero-cta {
    transform: translateY(-2px);
    filter: brightness(1.04);
  }

  @media screen and (max-width: 720px) {
    .hero-link {
      min-height: 440px;
    }

    .hero-content {
      min-height: 440px;
      gap: 0.85rem;
      padding: 1.2rem 1rem 1.3rem;
      justify-content: flex-end;
    }

    .hero-content h1 {
      font-size: clamp(1.55rem, 8vw, 2rem);
      max-width: 100%;
    }

    .hero-content p {
      font-size: 0.95rem;
    }
  }
</style>
