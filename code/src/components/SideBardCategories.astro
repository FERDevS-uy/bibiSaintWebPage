---
import type Product from "src/types/product";
import { withBasePath } from "@utils/basePath";
import { capitalize } from "@utils/capitalizeString";
import getColors from "@utils/getColors";
import type { subCategory } from "src/types/categoryList";
const { default: filterSVG } = await import("../assets/filter.svg?raw");

interface Props {
  categoryFather: string;
  arrayCategorys: subCategory[];
  products?: Product[];
  selected?: string;
}
const { categoryFather, arrayCategorys, products, selected } = Astro.props;

// Build hierarchical tree: subcategories with " - " become parent → children
interface TreeNode {
  name: string;
  href: string;
  children: { name: string; label: string; href: string }[];
}

const pathname = Astro.url.pathname;
const treeNodes: TreeNode[] = [];
const parentMap = new Map<string, TreeNode>();

arrayCategorys.forEach((subcat) => {
  const sepIdx = subcat.name.indexOf(" - ");
  if (sepIdx !== -1) {
    const parentName = subcat.name.slice(0, sepIdx);
    const childLabel = subcat.name.slice(sepIdx + 3);

    if (!parentMap.has(parentName)) {
      const node: TreeNode = {
        name: parentName,
        href: withBasePath(`/categories/${categoryFather}/${parentName}`, pathname),
        children: [],
      };
      parentMap.set(parentName, node);
      treeNodes.push(node);
    }
    parentMap.get(parentName)!.children.push({
      name: subcat.name,
      label: childLabel,
      href: withBasePath(`/categories/${categoryFather}/${subcat.name}`, pathname),
    });
  } else {
    if (!parentMap.has(subcat.name)) {
      const node: TreeNode = {
        name: subcat.name,
        href: withBasePath(`/categories/${categoryFather}/${subcat.name}`, pathname),
        children: [],
      };
      parentMap.set(subcat.name, node);
      treeNodes.push(node);
    }
  }
});

// Detect which parent accordion should be open
const activeParent = selected
  ? selected.includes(" - ")
    ? selected.slice(0, selected.indexOf(" - "))
    : selected
  : null;

// Colors: combinar el filtro heurístico por nombre (productos sin colors[] del proveedor)
// con los colores provistos por el CSV (Martina). Cada color expone su nombre real + hex.
type ColorChip = { key: string; label: string; hex: string };
const colorChipsMap = new Map<string, ColorChip>();

const colorCSS: Record<string, string> = {
  rojo: "#d32f2f",
  azul: "#1565c0",
  negro: "#1a1a1a",
  blanco: "#efefef",
  verde: "#2e7d32",
  amarillo: "#f9a825",
};

(products ?? []).forEach((p) => {
  // 1) Colores provistos directamente por el proveedor (CSV nueva columna `colores`).
  if (Array.isArray(p.colors) && p.colors.length > 0) {
    p.colors.forEach((c) => {
      const label = (c.name || "").trim();
      if (!label) return;
      const key = label.toLowerCase();
      if (!colorChipsMap.has(key)) {
        colorChipsMap.set(key, { key, label, hex: c.hex || "#cccccc" });
      }
    });
    return;
  }
  // 2) Fallback heurístico por nombre del producto.
  getColors(p.name).forEach((c) => {
    const key = c.toLowerCase();
    if (!colorChipsMap.has(key)) {
      colorChipsMap.set(key, { key, label: c, hex: colorCSS[key] ?? "#cccccc" });
    }
  });
});

const uniqueColors = Array.from(colorChipsMap.values());
---

<nav class="sf-sidebar">
  <!-- Mobile toggle -->
  <button class="sf-toggle" id="sf-toggle" aria-expanded="false" aria-controls="sf-body">
    <Fragment set:html={filterSVG} />
    <span>Filtros y categorías</span>
    <svg class="sf-chevron" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div id="sf-body" class="sf-body">

    <!-- Categories tree -->
    {treeNodes.length > 0 && (
      <div class="sf-section">
        <h3 class="sf-section-title">Categorías</h3>
        <ul class="sf-list">
          {treeNodes.map((node) => {
            const isParentActive = activeParent === node.name;
            const isExactSelected = selected === node.name;
            return (
              <li class="sf-item">
                {node.children.length > 0 ? (
                  <>
                    <button
                      class={`sf-parent-btn${isParentActive ? " is-active" : ""}`}
                      data-expanded={isParentActive ? "true" : "false"}
                      aria-expanded={isParentActive ? "true" : "false"}
                    >
                      {node.name}
                      <svg class="sf-chevron-sm" viewBox="0 0 20 20" fill="none">
                        <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </button>
                    <ul class={`sf-children${isParentActive ? " is-open" : ""}`}>
                      <li>
                        <a
                          href={node.href}
                          class={`sf-child-link${isExactSelected ? " is-selected" : ""}`}
                        >
                          Ver todos
                        </a>
                      </li>
                      {node.children.map((child) => (
                        <li>
                          <a
                            href={child.href}
                            class={`sf-child-link${selected === child.name ? " is-selected" : ""}`}
                          >
                            {child.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </>
                ) : (
                  <a
                    href={node.href}
                    class={`sf-link${isExactSelected ? " is-selected" : ""}`}
                  >
                    {node.name}
                  </a>
                )}
              </li>
            );
          })}
        </ul>
      </div>
    )}

    <!-- Color filter -->
    {uniqueColors.length > 0 && (
      <div class="sf-section">
        <h3 class="sf-section-title">Color</h3>
        <div id="sf-color-filter" class="sf-colors">
          {uniqueColors.map((color) => (
            <label class="sf-color-chip">
              <input
                type="checkbox"
                data-color={color.key}
                name="colors"
                class="sf-color-input"
              />
              <span
                class="sf-color-swatch"
                style={`background:${color.hex}`}
                aria-hidden="true"
              ></span>
              <span class="sf-color-label">{capitalize(color.label)}</span>
            </label>
          ))}
        </div>
      </div>
    )}

  </div>
</nav>

<style>
  .sf-sidebar {
    font-family: "Poppins", "Poppins Fallback", Arial, sans-serif;
    color: #222;
    background: #fff;
  }

  /* Mobile toggle */
  .sf-toggle {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 14px 20px;
    background: #fff;
    border: none;
    border-bottom: 1px solid #e0e0e0;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: inherit;
    color: #222;
    text-align: left;
    transition: background 0.15s;
  }
  .sf-toggle:hover { background: #fafafa; }
  .sf-toggle :global(svg:first-child) { width: 20px; height: 20px; flex-shrink: 0; }

  .sf-chevron {
    width: 18px;
    height: 18px;
    margin-left: auto;
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }
  .sf-toggle[aria-expanded="true"] .sf-chevron { transform: rotate(180deg); }

  /* Body */
  .sf-body {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease;
    background: #fff;
    border-bottom: 1px solid #e0e0e0;
  }
  .sf-body.is-open {
    max-height: 800px;
    overflow-y: auto;
  }

  /* Section */
  .sf-section {
    padding: 16px 20px;
    border-bottom: 1px solid #f2f2f2;
  }
  .sf-section:last-child { border-bottom: none; }

  .sf-section-title {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #aaa;
    margin: 0 0 10px;
  }

  /* Category list */
  .sf-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .sf-item { margin: 0; }

  .sf-link {
    display: block;
    padding: 7px 10px;
    border-radius: 8px;
    text-decoration: none;
    color: #333;
    font-size: 0.92rem;
    transition: background 0.15s, color 0.15s;
  }
  .sf-link:hover { background: #f5f5f5; }
  .sf-link.is-selected {
    background: #fdecea;
    color: #d32f2f;
    font-weight: 600;
  }

  /* Parent button */
  .sf-parent-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 7px 10px;
    border-radius: 8px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.92rem;
    font-weight: 500;
    color: #333;
    text-align: left;
    transition: background 0.15s, color 0.15s;
  }
  .sf-parent-btn:hover { background: #f5f5f5; }
  .sf-parent-btn.is-active {
    color: #d32f2f;
    font-weight: 700;
    background: #fdecea;
  }

  .sf-chevron-sm {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  .sf-parent-btn[aria-expanded="true"] .sf-chevron-sm { transform: rotate(180deg); }

  /* Children list */
  .sf-children {
    list-style: none;
    margin: 2px 0 4px 8px;
    padding: 0 0 0 14px;
    border-left: 2px solid #e8e8e8;
    display: none;
    flex-direction: column;
    gap: 1px;
  }
  .sf-children.is-open { display: flex; }

  .sf-child-link {
    display: block;
    padding: 5px 8px;
    border-radius: 6px;
    text-decoration: none;
    color: #555;
    font-size: 0.87rem;
    transition: background 0.15s, color 0.15s;
  }
  .sf-child-link:hover { background: #f5f5f5; color: #222; }
  .sf-child-link.is-selected {
    background: #fdecea;
    color: #d32f2f;
    font-weight: 600;
  }

  /* Color chips */
  .sf-colors {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .sf-color-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px 5px 7px;
    border-radius: 20px;
    border: 1.5px solid #e0e0e0;
    cursor: pointer;
    font-size: 0.82rem;
    transition: border-color 0.15s, background 0.15s;
    user-select: none;
  }
  .sf-color-chip:hover { border-color: #aaa; }
  .sf-color-chip:has(.sf-color-input:checked) {
    border-color: #d32f2f;
    background: #fdecea;
  }

  .sf-color-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .sf-color-swatch {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1.5px solid rgba(0, 0, 0, 0.12);
    display: block;
    flex-shrink: 0;
  }

  .sf-color-label {
    color: #333;
    font-family: inherit;
    line-height: 1;
  }

  /* Desktop */
  @media screen and (min-width: 600px) {
    .sf-toggle { display: none; }

    .sf-body {
      max-height: none !important;
      overflow: visible;
      border-bottom: none;
      transition: none;
      padding-top: 16px;
    }

    .sf-sidebar {
      width: 220px;
      min-width: 220px;
      flex-shrink: 0;
      border-right: 1px solid #ebebeb;
      min-height: 100dvh;
      padding-bottom: 40px;
    }

    .sf-section { padding: 10px 18px 14px; }
  }
</style>

<script>
  // @ts-nocheck
  window.addEventListener("DOMContentLoaded", () => {
    // Mobile toggle
    const toggle = document.getElementById("sf-toggle");
    const body = document.getElementById("sf-body");
    if (toggle && body) {
      toggle.addEventListener("click", () => {
        const isOpen = body.classList.toggle("is-open");
        toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
      });
    }

    // Category accordion
    document.querySelectorAll(".sf-parent-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        const children = btn.nextElementSibling;
        btn.setAttribute("aria-expanded", expanded ? "false" : "true");
        btn.classList.toggle("is-active", !expanded);
        children?.classList.toggle("is-open", !expanded);
      });
    });

    // Color filter — reads data-colors from each .producto_card
    const colorCheckboxes = document.querySelectorAll(".sf-color-input");
    if (colorCheckboxes.length > 0) {
      const params = new URLSearchParams(window.location.search);
      const initialColors = (params.get("colors") || "")
        .split(",")
        .map((c) => c.trim().toLowerCase())
        .filter(Boolean);

      if (initialColors.length > 0) {
        colorCheckboxes.forEach((cb) => {
          const color = (cb.dataset.color || "").toLowerCase();
          cb.checked = initialColors.includes(color);
        });
      }

      const applyFilter = () => {
        const checked = Array.from(colorCheckboxes)
          .filter((cb) => cb.checked)
          .map((cb) => cb.dataset.color ?? "");

        const urlParams = new URLSearchParams(window.location.search);
        if (checked.length === 0) {
          urlParams.delete("colors");
        } else {
          urlParams.set("colors", checked.join(","));
        }

        const query = urlParams.toString();
        const nextUrl = `${window.location.pathname}${query ? `?${query}` : ""}${window.location.hash}`;
        window.history.replaceState({}, "", nextUrl);

        document.querySelectorAll(".producto_card").forEach((card) => {
          if (checked.length === 0) {
            card.style.display = "";
            return;
          }
          const cardColors = (card.dataset.colors ?? "").split(",").filter(Boolean);
          card.style.display = checked.some((c) => cardColors.includes(c)) ? "" : "none";
        });
      };

      colorCheckboxes.forEach((cb) => cb.addEventListener("change", applyFilter));
      applyFilter();
    }
  });
</script>
