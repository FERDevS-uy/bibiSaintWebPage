---
import { cargarProductos } from "@utils/loadCSV";

const items = await cargarProductos();
---

<form class="searchForm">
  <input
    type="text"
    placeholder="Buscar productos..."
    autocomplete="off"
    id="search"
    class="searchInput"
  />

  <ul class="searchResults"></ul>
</form>

<style>
  form {
    width: 100%;
    position: relative;
    z-index: 10;
  }
  form.active input {
    border-radius: 5px 5px 0 0;
  }

  input {
    width: 100%;
    border-radius: 50px;
    padding: 5px 10px;
    border: 1px solid var(--line-color);
  }

  ul {
    position: absolute;
    background: linear-gradient(
      0deg,
      var(--p-b-color) 0%,
      var(--s-b-color) 100%
    );
    list-style: none;
  }

  :global(.searchForm li) {
  }
  :global(.searchForm li a) {
    display: block;
    padding: 10px 1rem;
    color: var(--secondary-text-color);
    text-decoration: none;
  }
  :global(.searchForm li a:hover) {
    color: var(--line-color);
    background-color: var(--p-b-color);
  }

  @media screen and (min-width: 1000px) {
    input {
      border-radius: 50px;
      padding: 10px 20px;
      outline: none;
    }
  }
</style>

<script define:vars={{ items }}>
  /* Definido en global.d.ts */
  window.productos = items;
</script>

<script>
  import Fuse from "fuse.js";

  const BASE_URL = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const urlQuery = params.get("q");

  const fuse = new Fuse(window.productos, {
    keys: [
      "name",
      "description",
      "id",
      "categories.name",
      "categories.subcategories.name",
    ],
    threshold: 0.3,
  });

  // Inicializar cada instancia del formulario de forma independiente
  document.querySelectorAll(".searchForm").forEach((form) => {
    const input = form.querySelector(".searchInput") as HTMLInputElement;
    const resultContainer = form.querySelector(".searchResults") as HTMLElement;

    if (urlQuery) input.value = urlQuery;

    form.addEventListener("submit", (e) => {
      e.preventDefault();

      const query = input.value.trim();

      if (query)
        window.location.href = `${BASE_URL}/search?q=${encodeURIComponent(query)}`;
      else window.location.href = BASE_URL;
    });

    input.addEventListener("input", () => {
      const query = input.value.trim();

      if (!query) {
        resultContainer.innerHTML = "";
        form.classList.remove("active");
        return;
      }

      const results = fuse.search(query).slice(0, 5);

      if (results.length === 0) form.classList.remove("active");
      else form.classList.add("active");

      resultContainer.innerHTML = results
        .map(
          (r) => `
        <li class="searchResultItem">
          <a href="${import.meta.env.BASE_URL}/producto/${r.item.id}">
          ${r.item.name}
          </a>
        </li>
      `,
        )
        .join("");
    });
  });
</script>
