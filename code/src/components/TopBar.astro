  <div class="top-bar__left">
    <span>Envío gratis a partir de $2.500</span>
  </div>

  <div class="top-bar__right">
    <a href="https://facebook.com/bibicartanumerologica" target="_blank" rel="noopener noreferrer" aria-label="Facebook" title="Facebook">
      <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
    </a>

    <a href="https://instagram.com/bibisventasonline" target="_blank" rel="noopener noreferrer" aria-label="Instagram" title="Instagram">
      <svg class="social-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="2.5" y="2.5" width="19" height="19" rx="6" stroke="currentColor" stroke-width="2"/>
        <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="2"/>
        <circle cx="18" cy="6" r="1.3" fill="currentColor"/>
      </svg>
    </a>

    <a href="https://wa.me/+59891361706" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" title="WhatsApp">
      <svg class="social-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 21L4.65 17.2A9 9 0 1 1 8.05 20.6L3 21Z" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M9 10a.5.5 0 0 0 0 1a5 5 0 0 0 5 5a.5.5 0 0 0 1 0v-1a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v.1a4 4 0 0 1-3.1-3.1h.1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5H9z" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
