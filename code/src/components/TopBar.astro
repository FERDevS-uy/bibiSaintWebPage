</div>

<style>
  .top-bar {
    background: #3a3a3a;
    color: #fff;
    font-size: 0.83rem;
    padding: 8px 20px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.65);
    font-family: "Poppins", "Poppins Fallback", Arial, sans-serif;
    gap: 12px;
  }

  .top-bar__spacer {
    min-width: 1px;
  }

  .top-bar__left {
    font-weight: 500;
    letter-spacing: 0.01em;
    text-align: center;
    justify-self: center;
    white-space: nowrap;
  }

  .top-bar__right {
    display: flex;
    gap: 18px;
    align-items: center;
    justify-self: end;
  }

  .social-icon {
    width: 23px;
    height: 23px;
    transition: opacity 0.2s ease, transform 0.2s ease;
    display: flex;
    flex-shrink: 0;
  }

  a {
    color: #fff;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  a:hover .social-icon {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  @media (max-width: 900px) {
    .top-bar {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: 6px;
      padding: 9px 12px;
    }

    .top-bar__spacer {
      display: none;
    }

    .top-bar__left {
      order: 2;
      white-space: normal;
      text-wrap: balance;
    }

    .top-bar__right {
      order: 1;
      justify-self: center;
      gap: 16px;
    }
  }

  @media (max-width: 680px) {
    .top-bar {
      font-size: 0.74rem;
      padding: 7px 10px;
    }

    .top-bar__right {
      gap: 14px;
    }

    .social-icon {
      width: 21px;
      height: 21px;
    }
  }
</style>
