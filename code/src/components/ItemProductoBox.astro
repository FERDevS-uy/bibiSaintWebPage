---
import type Product from "../types/product";
import { config } from "../config";
import AddToCartButton from "./AddToCartButton.astro";

export interface Props {
  producto: Product;
}

const { producto: p } = Astro.props;
---

<article class="producto_card">
  <a href={`${import.meta.env.BASE_URL}/producto/${p.id}`} class="card-img-link" title={p.name}>
    <img src={p.img[0]} alt={p.name} />
  </a>

  <div class="card-info">
    <span class="p-name">{p.name}</span>
    <span class="p-price">${p.price}</span>
    <div class="add-btn-wrapper">
      <AddToCartButton producto={p} variant="full" />
    </div>
  </div>
</article>

<style>
  .producto_card {
    --radius: 8px;
    width: 100%;
    background: #fff;
    border-radius: var(--radius);
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.08),
      0 1px 3px rgba(0, 0, 0, 0.06);
    transition:
      transform 0.22s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.22s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    cursor: pointer;
    position: relative;
  }

  /* 3D lift on hover — desktop */
  @media (hover: hover) {
    .producto_card:hover {
      transform: translateY(-6px) scale(1.02);
      box-shadow:
        0 12px 32px rgba(0, 0, 0, 0.14),
        0 4px 10px rgba(0, 0, 0, 0.1);
    }

    .producto_card:hover .add-btn-wrapper {
      opacity: 1;
      transform: translateY(0);
      pointer-events: all;
    }
  }

  /* Image */
  .card-img-link {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .producto_card:hover img {
    transform: scale(1.04);
  }

  /* Info section */
  .card-info {
    padding: 10px 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .p-name {
    font-size: 0.92rem;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .p-price {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  /* Add to cart button wrapper */
  .add-btn-wrapper {
    margin-top: 4px;
    /* Mobile: always visible */
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  /* Desktop: hidden until hover */
  @media (hover: hover) and (min-width: 768px) {
    .add-btn-wrapper {
      opacity: 0;
      transform: translateY(8px);
      pointer-events: none;
    }
  }

  @media screen and (min-width: 1000px) {
    .producto_card {
      width: 220px;
      margin-bottom: 0;
    }
  }
</style>
