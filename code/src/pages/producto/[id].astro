---
import { cargarProductos } from "../../utils/loadCSV";
import Layout from "../../layouts/Layout.astro";
import { config } from "../../config";
import NumberInput from "@components/NumberInput.astro";
import type Product from "../../types/product";
import {
  getDisplayCategoryName,
  getDisplaySubcategories,
} from "@utils/categoryNormalization";

export function getStaticPaths() {
  const productos = cargarProductos();

  return productos.map((p) => {
    const { id, relacionados, ...rest } = p;

    const productosRelacionados = productos.filter((p) =>
      relacionados.includes(p.id),
    );

    return {
      params: { id },
      props: { id, productosRelacionados, ...rest },
    };
  });
}

const {
  id,
  name,
  img,
  price,
  categories,
  paymentLink,
  description,
  productosRelacionados: relacionados,
} = Astro.props;

const productForCategoryPath: Product = {
  id,
  name,
  description,
  price,
  img,
  categories,
  paymentLink,
  enOferta: false,
  relacionados: [],
};

const displayCategoryName = getDisplayCategoryName(productForCategoryPath);
const displaySubcategories = getDisplaySubcategories(productForCategoryPath);
const detailedSubcategory = displaySubcategories.find((sub) => sub.includes(" - "));
const groupSubcategory = detailedSubcategory
  ? detailedSubcategory.split(" - ")[0]
  : displaySubcategories[0];
const leafSubcategory = detailedSubcategory || displaySubcategories[0];

const isRopa = displayCategoryName === "Ropa";
---

<Layout
  pageTitle={`${config.pageTitle} - ${name}`}
  description={description}
  pageImage={img[0]}
>
  <section class="productContainer">
    <!-- BREADCRUMB -->
    <div class="breadcrumb">
      <a href={`${import.meta.env.BASE_URL}/categories/${displayCategoryName}`}
        >{displayCategoryName}</a
      >

      {groupSubcategory && (
        <>
          {" / "}
          <a href={`${import.meta.env.BASE_URL}/categories/${displayCategoryName}/${groupSubcategory}`}>
            {groupSubcategory}
          </a>
        </>
      )}

      {leafSubcategory && leafSubcategory !== groupSubcategory && (
        <>
          {" / "}
          <a href={`${import.meta.env.BASE_URL}/categories/${displayCategoryName}/${leafSubcategory}`}>
            {leafSubcategory.replace(`${groupSubcategory} - `, "")}
          </a>
        </>
      )}
    </div>

    <div class="product_layout">
      <!-- LEFT IMAGE SECTION -->
      <div class="gallery">
        <img class="mainImg" src={img[0]} alt={name} />

        <div class="thumbs">
          {img.map((i) => <img src={i} alt="" class="thumb" />)}
        </div>
      </div>

      <!-- RIGHT INFO -->
      <div class="infoBox">
        <span class="stock">En Stock</span>
        <h1 class="name">{name}</h1>

        <div class="meta">
          <p><strong>ID:</strong> {id}</p>
          <p><strong>Marca:</strong> {categories?.name}</p>
        </div>
        
        <div class="description-box">
          <strong class="desc-title">Descripción del Producto:</strong>
          <div class="desc-content">
            {description.split('. ').map((sentence: string) => 
               sentence.trim() ? <p>{sentence}.</p> : null
            )}
          </div>
        </div>

        {
          isRopa && (
            <>
              <strong>Talle:</strong>
              <div class="sizes" id="sizesSelector">
                <button type="button" class="size" data-size="S">S</button>
                <button type="button" class="size" data-size="M">M</button>
                <button type="button" class="size" data-size="L">L</button>
                <button type="button" class="size" data-size="XL">XL</button>
              </div>
              <p id="sizeFeedback" class="size-feedback hidden">Selecciona un talle para continuar.</p>
            </>
          )
        }

        <div class="priceRow">
          <span class="price">${price}</span>
          <NumberInput
            id="cartQty"
            name="pasajeros"
            initialValue={2}
            min={1}
            max={10}
          />
          <button
            type="button"
            id="addToCartBtn"
            class="buyBtn"
            data-id={Astro.props.id}
          >
            Añadir al Carrito
          </button>
        </div>
      </div>
    </div>

    <!-- RELATED PRODUCTS -->

    {
      relacionados && relacionados.length > 0 && (
        <div class="related">
          <h2>Productos Relacionados</h2>

          <div class="relatedList">
            {relacionados.map((prod: any) => (
              <div class="card">
                <a href={`${import.meta.env.BASE_URL}/producto/${prod.id}`}>
                  <div class="cardImg">
                    <img class="cardImg" src={prod.img[0]} alt={prod.name} />
                  </div>
                  <span class="cardTitle">{prod.name}</span>
                  <span class="cardPrice">${prod.price}</span>
                </a>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </section>
</Layout>

<style>
  .productContainer {
    max-width: 1200px;
    min-height: 100vh;
    margin: 0 auto;
    padding: 20px;
    font-family: "Poppins", sans-serif;
    margin-bottom: 3rem;
  }

  /**** Breadcrumb *****/
  .breadcrumb {
    font-size: 14px;
    font-weight: 700;
    color: #4a4a4a;
    margin-bottom: 25px;
    padding-bottom: 12px;
    border-bottom: 1px solid #eaeaea;
  }
  .breadcrumb a {
    text-decoration: none;
    color: #4a4a4a;
    transition: color 0.2s;
  }
  .breadcrumb a:hover {
    color: #e67e22;
  }

  /**** Layout *****/
  .product_layout {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /**** Gallery *****/
  .gallery {
    width: 100%;
  }

  .mainImg {
    width: 100%;
    height: auto;
    aspect-ratio: 1/1;
    object-fit: cover;
    background: #fcfcfc;
    border-radius: 12px;
    display: block;
    margin-bottom: 15px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
  }

  .thumbs {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 5px; 
  }

  .thumb {
    width: 70px;
    height: 70px;
    border-radius: 8px;
    object-fit: cover;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }
  .thumb:hover {
    border-color: #e67e22;
  }

  /**** Info box *****/
  .infoBox {
    padding: 0;
  }

  .stock {
    display: inline-block;
    background: #27ae60;
    color: white;
    font-weight: 700;
    font-size: 12px;
    padding: 6px 12px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 15px;
    border-radius: 20px;
  }

  .name {
    font-size: 32px;
    font-weight: 800;
    line-height: 1.25;
    margin: 0 0 15px 0;
    color: #1a1a1a;
  }

  .meta {
    font-size: 14px;
    color: #666;
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .meta p {
    margin: 4px 0;
  }

  .meta strong {
    font-weight: 700;
    color: #333;
  }

  /* Description Box Estético */
  .description-box {
    background: #fafbfc;
    border-left: 4px solid #e67e22;
    padding: 20px 24px;
    margin: 25px 0;
    border-radius: 4px 12px 12px 4px;
    height: 240px;
    display: flex;
    flex-direction: column;
  }

  .desc-title {
    font-size: 16px;
    font-weight: 800;
    color: #2c3e50;
    margin-bottom: 12px;
    display: block;
  }

  .desc-content p {
    font-size: 14.5px;
    line-height: 1.7;
    color: #4b5563;
    margin: 0 0 8px 0;
    position: relative;
    padding-left: 14px;
  }

  .desc-content p::before {
    content: '•';
    position: absolute;
    left: 0;
    color: #e67e22;
    font-weight: bold;
  }

  .desc-content {
    overflow-y: auto;
    padding-right: 6px;
  }

  .desc-content::-webkit-scrollbar {
    width: 8px;
  }

  .desc-content::-webkit-scrollbar-thumb {
    background: #d0d0d0;
    border-radius: 10px;
  }

  strong {
    font-weight: 800;
  }

  /**** Sizes *****/
  .sizes {
    display: flex;
    gap: 5px;
    margin: 10px 0 20px 0;
  }

  .size {
    width: 40px;
    height: 40px;
    background: white;
    border: 1px solid #000;
    color: #000;
    font-size: 32px;
    font-weight: 250;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .size:hover {
    background: #f0f0f0;
  }

  .size.selected {
    background: var(--p-b-color);
    border-color: var(--p-b-color);
    color: #fff;
  }

  .size-feedback {
    margin-top: -10px;
    margin-bottom: 10px;
    color: var(--p-b-color);
    font-size: 0.9rem;
    font-weight: 600;
  }

  /**** Price & Actions *****/
  .priceRow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 15px;
    margin-top: 20px;
  }

  .priceRow .price {
    display: block;
    height: 50px;
    line-height: 160%;
    font-size: 32px;
    font-weight: 800;
    color: #000;
    margin-right: auto;
  }

  /* Adjust NumberInput styling overlap if possible, otherwise wrapper */
  /* Assuming NumberInput generates a wrapper, we might need to target it deep or adjacent */

  .buyBtn {
    background: var(--p-b-color);
    color: white;
    border: none;
    padding: 0 20px;
    height: 44px; /* Match typical touch target */
    /*font-size: 16px;*/
    font-weight: 700;
    cursor: pointer;
    border-radius: 4px;
    flex: 1;
    min-width: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .buyBtn:hover {
    background: var(--s-b-color);
  }

  /**** Related Products *****/
  .related {
    margin-top: 50px;
    border-top: 1px solid #000;
    padding-top: 20px;
  }

  .related h2 {
    font-size: 24px;
    font-weight: 800;
    margin-bottom: 20px;
    text-align: center;
  }

  .relatedList {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }

  .card {
    background: white;
    text-align: center;
  }

  .card a {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .cardImg {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    margin-bottom: 10px;
  }

  .cardTitle {
    font-size: 14px;
    font-weight: 700;
    display: block;
    margin-bottom: 5px;
  }

  .cardPrice {
    font-size: 16px;
    font-weight: 800;
    display: block;
    margin-bottom: 10px;
  }

  .cardBtn {
    background: transparent; /* Or keep black if desired, but reference focuses on main product */
    color: #000;
    text-decoration: underline;
    border: none;
    font-weight: 600;
    cursor: pointer;
    padding: 0;
  }

  /**** Desktop Media Query *****/
  @media (min-width: 768px) {
    .product_layout {
      flex-direction: row;
      align-items: flex-start;
    }

    .gallery {
      flex: 1;
      max-width: 50%;
    }

    .infoBox {
      flex: 1;
      padding-left: 20px;
    }

    .price {
      width: auto;
      margin-right: 20px;
    }

    .buyBtn {
      flex: initial;
      width: auto;
    }

    .relatedList {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>

<script>
  import addToCart from "../../utils/addToCart";
  function initProductDetail() {
    const addBtn = document.getElementById("addToCartBtn") as HTMLButtonElement | null;
    if (!addBtn || addBtn.dataset.bound === "true") return;

    addBtn.dataset.bound = "true";
    const sizesSelector = document.getElementById("sizesSelector");
    const sizeFeedback = document.getElementById("sizeFeedback");
    let selectedSize = "";

    if (sizesSelector) {
      const sizeButtons = sizesSelector.querySelectorAll<HTMLButtonElement>(".size");
      sizeButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          selectedSize = btn.dataset.size || "";
          sizeButtons.forEach((item) => item.classList.remove("selected"));
          btn.classList.add("selected");
          sizeFeedback?.classList.add("hidden");
        });
      });
    }

    addBtn.addEventListener("click", () => {
      const qtyInput = document.getElementById("cartQty") as HTMLInputElement;
      const price = document.querySelector(".price") as HTMLSpanElement;
      const name = document.querySelector(".name") as HTMLHeadingElement;
      const id = addBtn.getAttribute("data-id") ?? "";
      const img = document.querySelector(".thumbs img") as HTMLImageElement;
      const qty = parseInt(qtyInput.value, 10);

      const isClothing = Boolean(sizesSelector);
      if (isClothing && !selectedSize) {
        sizeFeedback?.classList.remove("hidden");
        return;
      }

      const idToCart = selectedSize ? `${id}__${selectedSize}` : id;
      const nameToCart = selectedSize
        ? `${name.innerText} (Talle ${selectedSize})`
        : name.innerText;

      addToCart(
        idToCart,
        nameToCart,
        price.innerText.replace("$", "").replace(",", "."),
        qty,
        img.src,
      );

      window.updateCartCount && window.updateCartCount();
      addBtn.textContent = "¡Agregado!";
      setTimeout(() => (addBtn.textContent = "Agregar al carrito"), 1200);
    });
  }

  initProductDetail();
  document.addEventListener("astro:page-load", initProductDetail);
</script>
