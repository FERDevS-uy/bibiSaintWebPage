---
import Layout from "../../layouts/Layout.astro";
import { config } from "../../config";
import { withBasePath } from "@utils/basePath";
import NumberInput from "@components/NumberInput.astro";
import ProductGallery from "@components/ProductGallery.jsx";
import { ProductHydrator } from "@stores/ProductHydrator";
import type Product from "../../types/product";
import {
  getDisplayCategoryName,
  getDisplaySubcategories,
} from "@utils/categoryNormalization";
import { isTallBoot } from "@utils/isTallBoot";
import { loadProductById, loadRelatedProducts } from "../../utils/loadProducts";

const { id } = Astro.params;

const product = await loadProductById(id!);

if (!product) {
  return Astro.redirect("/404", 404);
}

const {
  name,
  img,
  price,
  categories,
  paymentLink,
  description,
  colors,
  enOferta,
  relacionados: relacionadosIds,
} = product;

const relacionados = await loadRelatedProducts(relacionadosIds);

const productForCategoryPath: Product = {
  id,
  name,
  description,
  price,
  img,
  categories,
  paymentLink,
  enOferta: false,
  relacionados: [],
};

const displayCategoryName = getDisplayCategoryName(productForCategoryPath);
const displaySubcategories = getDisplaySubcategories(productForCategoryPath);
const detailedSubcategory = displaySubcategories.find((sub) => sub.includes(" - "));
const groupSubcategory = detailedSubcategory
  ? detailedSubcategory.split(" - ")[0]
  : displaySubcategories[0];
const leafSubcategory = detailedSubcategory || displaySubcategories[0];

const isRopa = displayCategoryName === "Ropa";
const disableColorSelection = /^tal-/i.test(String(id || ""));
const runtimeStockCheckEnabled = import.meta.env.PUBLIC_ENABLE_STOCK_CHECK !== "false";
const primaryProviderLink = paymentLink?.[0]?.url ?? "";
const martinaCode = import.meta.env.PUBLIC_MARTINA_CODE || "202605";
const martinaCountryId = import.meta.env.PUBLIC_MARTINA_COUNTRY_ID || "598";
const isMartinaProduct = String(id).toLowerCase().startsWith("mdt-");
const isKaiProduct = String(id).toLowerCase().startsWith("kai-") || primaryProviderLink.includes("kaideco.uy/products/");
const isNuvexProduct = primaryProviderLink.includes("nuvex.uy");
const isAlondraProduct =
  String(id).toLowerCase().startsWith("alo-")
  || primaryProviderLink.includes("alondra.com.uy")
  || primaryProviderLink.includes("alondra-ecommerce");
const showRuntimeStockCheck =
  runtimeStockCheckEnabled
  && (isMartinaProduct || isKaiProduct || isNuvexProduct || isAlondraProduct);
const pathname = Astro.url.pathname;
---

<Layout
  pageTitle={`${config.pageTitle} - ${name}`}
  description={description}
  pageImage={img[0]}
>
  <ProductHydrator
    client:load
    id={id}
    name={name}
    price={price}
    img={img[0]}
    enOferta={Boolean(enOferta)}
  />
  <section class="productContainer">
    <!-- BREADCRUMB -->
    <div class="breadcrumb">
      <a href={withBasePath(`/categories/${displayCategoryName}`, pathname)}
        >{displayCategoryName}</a
      >

      {groupSubcategory && (
        <>
          {" / "}
          <a href={withBasePath(`/categories/${displayCategoryName}/${groupSubcategory}`, pathname)}>
            {groupSubcategory}
          </a>
        </>
      )}

      {leafSubcategory && leafSubcategory !== groupSubcategory && (
        <>
          {" / "}
          <a href={withBasePath(`/categories/${displayCategoryName}/${leafSubcategory}`, pathname)}>
            {leafSubcategory.replace(`${groupSubcategory} - `, "")}
          </a>
        </>
      )}
    </div>

    <div class="product_layout">
      <!-- LEFT IMAGE SECTION (isla React, carga lazy) -->
      {/* Galería como isla React: carga lazy, marca producto como no disponible si fallan las imágenes */}
      <ProductGallery images={img} name={name} description={description} id={id} client:load />
      <div id="productImagesData" data-images={JSON.stringify(img)} style="display:none"></div>

      <!-- RIGHT INFO -->
      <div class="infoBox">
        <span id="stockBadge" class="stock">En Stock</span>
        <h1 class="name">{name}</h1>

        <div class="meta">
          <p><strong>ID:</strong> {id}</p>
          <p><strong>Marca:</strong> {categories?.name}</p>
        </div>
        
        <div class="description-box">
          <strong class="desc-title">Descripción del Producto:</strong>
          <div class="desc-content">
            {description.split('. ').map((sentence: string) => 
               sentence.trim() ? <p>{sentence}.</p> : null
            )}
          </div>
        </div>

        <div
          id="colorsBlock"
          data-disable-selection={disableColorSelection ? "true" : "false"}
          class={`colors-block${colors && colors.length > 0 && !disableColorSelection ? "" : " hidden"}`}
        >
          <strong>
            Color: <span id="colorName" class="color-name">{colors?.[0]?.name ?? ""}</span>
          </strong>
          <div class="colors" id="colorsSelector">
            {colors && colors.length > 0 && !disableColorSelection && colors.map((c, i) => (
              <button
                type="button"
                class={`swatch${i === 0 ? " selected" : ""}`}
                style={`background-color:${c.hex || "#cccccc"}`}
                data-color-id={String(c.id)}
                data-color-name={c.name}
                data-color-images={JSON.stringify(c.images || [])}
                data-color-sizes={JSON.stringify(c.sizes || [])}
                title={c.name}
                aria-label={c.name}
              ></button>
            ))}
          </div>
        </div>

        <div id="sizesBlock" class={`sizes-block${isRopa ? "" : " hidden"}`}>
          <strong>Talle:</strong>
          <div class="sizes" id="sizesSelector">
            <button type="button" class="size" data-size="XS">XS</button>
            <button type="button" class="size" data-size="S">S</button>
            <button type="button" class="size" data-size="M">M</button>
            <button type="button" class="size" data-size="L">L</button>
            <button type="button" class="size" data-size="XL">XL</button>
            <button type="button" class="size" data-size="XXL">XXL</button>
          </div>
          <p id="sizeFeedback" class="size-feedback hidden">Selecciona un talle disponible para continuar.</p>
        </div>

        <div class="priceRow">
          <span id="productPrice" class="price">${price}</span>
          <NumberInput
            id="cartQty"
            name="pasajeros"
            initialValue={1}
            min={1}
            max={10}
          />
          <button
            type="button"
            id="addToCartBtn"
            class="buyBtn"
            data-id={id}
          >
            Añadir al Carrito
          </button>
        </div>

        {
          showRuntimeStockCheck && (
            <div class="runtimeStockCheck" id="runtimeStockCheck">
              <button
                type="button"
                id="checkStockBtn"
                class="checkStockBtn"
                data-product-id={id}
                data-provider-link={primaryProviderLink}
                data-martina-code={martinaCode}
                data-martina-country-id={martinaCountryId}
              >
                Verificar stock y precio
              </button>
              <p id="stockCheckStatus" class="stockCheckStatus">Consulta en vivo desde proveedor.</p>
            </div>
          )
        }
      </div>
    </div>

    <!-- RELATED PRODUCTS -->

    {
      relacionados && relacionados.length > 0 && (
        <div class="related">
          <h2>Productos Relacionados</h2>

          <div class="relatedList">
            {relacionados.map((prod: any) => {
              const tall = isTallBoot(prod.name, prod.description, prod.id);
              return (
              <div class="card">
                <a href={withBasePath(`/producto/${prod.id}`, pathname)}>
                  <div class={`cardImg${tall ? " cardImg--tall" : ""}`}>
                    <img loading="lazy" class={`cardImg${tall ? " cardImg--tall" : ""}`} src={prod.img[0]} alt={prod.name} />
                  </div>
                  <span class="cardTitle">{prod.name}</span>
                  <span class="cardPrice">${prod.price}</span>
                </a>
              </div>
              );
            })}
          </div>
        </div>
      )
    }
  </section>
</Layout>

<style>
  .productContainer {
    box-sizing: border-box;
    width: 100%;
    max-width: 1200px;
    min-height: 100vh;
    margin: 0 auto;
    padding: 20px;
    font-family: "Poppins", "Poppins Fallback", sans-serif;
    margin-bottom: 3rem;
    overflow-x: clip;
  }

  /**** Breadcrumb *****/
  .breadcrumb {
    font-size: 14px;
    font-weight: 700;
    color: #4a4a4a;
    margin-bottom: 25px;
    padding-bottom: 12px;
    border-bottom: 1px solid #eaeaea;
  }
  .breadcrumb a {
    text-decoration: none;
    color: #4a4a4a;
    transition: color 0.2s;
  }
  .breadcrumb a:hover {
    color: #e67e22;
  }

  /**** Layout *****/
  .product_layout {
    box-sizing: border-box;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 40px;
    min-width: 0;
  }

  .infoBox,
  .priceRow,
  .colors,
  .sizes {
    min-width: 0;
    max-width: 100%;
  }

  /**** Gallery (estilos en src/styles/components/ProductGallery.css) *****/

  /**** Info box *****/
  .infoBox {
    padding: 0;
  }

  .stock {
    display: inline-block;
    background: #27ae60;
    color: white;
    font-weight: 700;
    font-size: 12px;
    padding: 6px 12px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 15px;
    border-radius: 20px;
  }

  .name {
    font-size: 32px;
    font-weight: 800;
    line-height: 1.25;
    margin: 0 0 15px 0;
    color: #1a1a1a;
  }

  .meta {
    font-size: 14px;
    color: #666;
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .meta p {
    margin: 4px 0;
  }

  .meta strong {
    font-weight: 700;
    color: #333;
  }

  /* Description Box Estético */
  .description-box {
    background: #fafbfc;
    border-left: 4px solid #e67e22;
    padding: 20px 24px;
    margin: 25px 0;
    border-radius: 4px 12px 12px 4px;
    height: 240px;
    display: flex;
    flex-direction: column;
  }

  .desc-title {
    font-size: 16px;
    font-weight: 800;
    color: #2c3e50;
    margin-bottom: 12px;
    display: block;
  }

  .desc-content p {
    font-size: 14.5px;
    line-height: 1.7;
    color: #4b5563;
    margin: 0 0 8px 0;
    position: relative;
    padding-left: 14px;
  }

  .desc-content p::before {
    content: '•';
    position: absolute;
    left: 0;
    color: #e67e22;
    font-weight: bold;
  }

  .desc-content {
    overflow-y: auto;
    padding-right: 6px;
  }

  .desc-content::-webkit-scrollbar {
    width: 8px;
  }

  .desc-content::-webkit-scrollbar-thumb {
    background: #d0d0d0;
    border-radius: 10px;
  }

  strong {
    font-weight: 800;
  }

  /**** Sizes *****/
  .sizes-block.hidden {
    display: none;
  }

  .sizes {
    display: flex;
    gap: 5px;
    margin: 10px 0 20px 0;
  }

  .size {
    width: 40px;
    height: 40px;
    background: white;
    border: 1px solid #000;
    color: #000;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  :global(.size) {
    width: 40px;
    height: 40px;
    background: white;
    border: 1px solid #000;
    color: #000;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .size:hover {
    background: #f0f0f0;
  }

  :global(.size:hover) {
    background: #f0f0f0;
  }

  .size.selected {
    background: var(--p-b-color);
    border-color: var(--p-b-color);
    color: #fff;
  }

  :global(.size.selected) {
    background: var(--p-b-color);
    border-color: var(--p-b-color);
    color: #fff;
  }

  .size.unavailable,
  .size[disabled] {
    background: #f3f3f3;
    color: #b1b1b1;
    border-color: #e0e0e0;
    cursor: not-allowed;
    position: relative;
  }

  :global(.size.unavailable),
  :global(.size[disabled]) {
    background: #f3f3f3;
    color: #b1b1b1;
    border-color: #e0e0e0;
    cursor: not-allowed;
    position: relative;
  }

  .size.unavailable::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top right,
      transparent calc(50% - 1px),
      #c9c9c9 calc(50% - 1px),
      #c9c9c9 calc(50% + 1px),
      transparent calc(50% + 1px)
    );
    pointer-events: none;
  }

  :global(.size.unavailable::after) {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top right,
      transparent calc(50% - 1px),
      #c9c9c9 calc(50% - 1px),
      #c9c9c9 calc(50% + 1px),
      transparent calc(50% + 1px)
    );
    pointer-events: none;
  }

  /**** Colors *****/
  .colors-block {
    margin: 10px 0 16px 0;
  }
  /* Global rules to cover dynamically-inserted .swatch buttons (client or server without scoped attr) */
  :global(.swatch) {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #e5e5e5;
    background: #ccc;
    cursor: pointer;
    padding: 0;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  :global(.swatch):hover {
    transform: scale(1.1);
  }
  :global(.swatch).selected {
    border-color: #111;
    transform: scale(1.1);
  }
  .colors-block.hidden {
    display: none;
  }
  .color-name {
    font-weight: 500;
    text-transform: capitalize;
  }
  .colors {
    display: flex;
    gap: 8px;
    margin-top: 6px;
    flex-wrap: wrap;
  }
  .swatch {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #e5e5e5;
    background: #ccc;
    cursor: pointer;
    padding: 0;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .swatch:hover {
    transform: scale(1.1);
  }
  .swatch.selected {
    border-color: #111;
    transform: scale(1.1);
  }

  .size-feedback {
    margin-top: -10px;
    margin-bottom: 10px;
    color: var(--p-b-color);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .size-feedback.hidden,
  .hidden {
    display: none;
  }

  /**** Price & Actions *****/
  .priceRow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }

  .priceRow .price {
    display: block;
    height: auto;
    line-height: 1.2;
    font-size: 32px;
    font-weight: 800;
    color: #000;
    margin-right: 0;
    min-width: 140px;
  }

  /* Adjust NumberInput styling overlap if possible, otherwise wrapper */
  /* Assuming NumberInput generates a wrapper, we might need to target it deep or adjacent */

  .buyBtn {
    background: var(--p-b-color);
    color: white;
    border: none;
    padding: 0 20px;
    height: 44px; /* Match typical touch target */
    /*font-size: 16px;*/
    font-weight: 700;
    cursor: pointer;
    border-radius: 4px;
    flex: 1;
    min-width: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .buyBtn:hover {
    background: var(--s-b-color);
  }

  .runtimeStockCheck {
    margin-top: 10px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .checkStockBtn {
    width: fit-content;
    max-width: 100%;
    border: 1px solid #222;
    background: #fff;
    color: #222;
    font-weight: 600;
    border-radius: 999px;
    padding: 8px 14px;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .checkStockBtn:hover {
    background: #f4f4f4;
  }

  .checkStockStatus {
    margin: 0;
    font-size: 0.85rem;
    color: #5a5a5a;
  }

  .checkStockStatus.is-error {
    color: #b42318;
  }

  .checkStockStatus.is-ok {
    color: #157f3b;
  }

  /**** Related Products *****/
  .related {
    margin-top: 50px;
    border-top: 1px solid #000;
    padding-top: 20px;
  }

  .related h2 {
    font-size: 24px;
    font-weight: 800;
    margin-bottom: 20px;
    text-align: center;
  }

  .relatedList {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }

  .card {
    background: white;
    text-align: center;
  }

  .card a {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .cardImg {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: contain;
    object-position: top;
    margin-bottom: 10px;
  }

  /* Botas largas: que la imagen se vea completa (sin recorte) */
  .cardImg--tall {
    object-fit: contain;
    object-position: center;
    background: #fcfcfc;
  }

  .cardTitle {
    font-size: 14px;
    font-weight: 700;
    display: block;
    margin-bottom: 5px;
  }

  .cardPrice {
    font-size: 16px;
    font-weight: 800;
    display: block;
    margin-bottom: 10px;
  }

  .cardBtn {
    background: transparent; /* Or keep black if desired, but reference focuses on main product */
    color: #000;
    text-decoration: underline;
    border: none;
    font-weight: 600;
    cursor: pointer;
    padding: 0;
  }

  /**** Desktop Media Query *****/
  @media (max-width: 767px) {
    .productContainer {
      padding-inline: 14px;
    }

    .priceRow {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .priceRow .price {
      min-width: 0;
      font-size: 30px;
    }

    .buyBtn {
      width: 100%;
      min-width: 0;
    }

    .sizes {
      flex-wrap: wrap;
      row-gap: 8px;
    }

    .colors {
      overflow-x: auto;
      overflow-y: hidden;
      overscroll-behavior-x: contain;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 2px;
    }
  }

  @media (min-width: 768px) {
    .product_layout {
      flex-direction: row;
      align-items: flex-start;
    }

    .infoBox {
      flex: 1;
      padding-left: 20px;
    }

    .priceRow {
      display: grid;
      grid-template-columns: auto auto minmax(210px, 1fr);
      align-items: center;
      gap: 10px;
    }

    .priceRow :global(.number-control) {
      width: 92px;
      height: 44px;
    }

    .priceRow :global(.number-control .control-btn) {
      width: 32px;
      font-size: 21px;
    }

    .priceRow :global(.number-control input[type="number"]) {
      font-size: 1.75rem;
      font-variant-numeric: tabular-nums;
    }

    .priceRow .price {
      margin-right: 0;
    }

    .buyBtn {
      width: 100%;
      min-width: 210px;
      height: 44px;
      flex: initial;
    }

    .runtimeStockCheck {
      flex-direction: row;
      align-items: center;
      gap: 10px;
      margin-top: 8px;
    }

    .checkStockStatus {
      font-size: 0.82rem;
    }

    .relatedList {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>

<script>
  import addToCart from "../../utils/addToCart";
  function initProductDetail() {
    const addBtn = document.getElementById("addToCartBtn") as HTMLButtonElement | null;
    if (!addBtn || addBtn.dataset.bound === "true") return;

    addBtn.dataset.bound = "true";
    const sizesSelector = document.getElementById("sizesSelector");
    const sizesBlock = document.getElementById("sizesBlock");
    const sizeFeedback = document.getElementById("sizeFeedback");
    const colorsBlockRoot = document.getElementById("colorsBlock") as HTMLElement | null;
    const colorSelectionDisabled =
      colorsBlockRoot?.dataset.disableSelection === "true";
    if (colorSelectionDisabled && colorsBlockRoot) {
      colorsBlockRoot.classList.add("hidden");
    }
    let selectedSize = "";
    let requiresSizeSelection = Boolean(
      sizesSelector && sizesBlock && !sizesBlock.classList.contains("hidden"),
    );

    const clearSelectedSize = () => {
      selectedSize = "";
      if (!sizesSelector) return;
      sizesSelector
        .querySelectorAll<HTMLButtonElement>(".size")
        .forEach((btn) => btn.classList.remove("selected"));
    };

    // Estado de talles/colores disponibles (compartido con el verificador de stock)
      const availableSizesByColor = new Map<number, Set<string>>();
      let selectedColorId: number | null = null;
      let selectedColorName: string | null = null;

    const setSizeRequirement = (required: boolean) => {
      requiresSizeSelection = required;
      if (!sizesBlock || !sizesSelector) return;
      sizesBlock.classList.toggle("hidden", !required);
      if (!required) {
        clearSelectedSize();
        sizeFeedback?.classList.add("hidden");
        sizesSelector
          .querySelectorAll<HTMLButtonElement>(".size")
          .forEach((btn) => {
            btn.classList.remove("unavailable", "selected");
            btn.disabled = false;
          });
      }
    };

    if (sizesSelector) {
      sizesSelector.addEventListener("click", (event) => {
        const target = event.target as HTMLElement;
        const button = target.closest(".size") as HTMLButtonElement | null;
        if (!button) return;
        if (button.classList.contains("unavailable") || button.disabled) return;

        selectedSize = button.dataset.size || "";
        const sizeButtons = sizesSelector.querySelectorAll<HTMLButtonElement>(".size");
        sizeButtons.forEach((item) => item.classList.remove("selected"));
        button.classList.add("selected");
        sizeFeedback?.classList.add("hidden");
      });
    }

    addBtn.addEventListener("click", () => {
      const qtyInput = document.getElementById("cartQty") as HTMLInputElement;
      const price = document.querySelector(".price") as HTMLSpanElement;
      const name = document.querySelector(".name") as HTMLHeadingElement;
      const id = addBtn.getAttribute("data-id") ?? "";
      const img = document.querySelector(".gallery .mainImg") as HTMLImageElement | null;
      const qty = parseInt(qtyInput.value, 10);

      const isClothing = Boolean(sizesSelector) && requiresSizeSelection;
      if (isClothing && !selectedSize) {
        if (sizeFeedback) {
          sizeFeedback.textContent = "Selecciona un talle para continuar.";
          sizeFeedback.classList.remove("hidden");
        }
        return;
      }

      // validar contra disponibilidad si ya conocemos el stock real
      if (isClothing && availableSizesByColor.size > 0) {
        const setForColor =
          selectedColorId !== null
            ? availableSizesByColor.get(selectedColorId)
            : null;
        if (setForColor && !setForColor.has(selectedSize)) {
          if (sizeFeedback) {
            sizeFeedback.textContent =
              "Ese talle no está disponible para el color elegido.";
            sizeFeedback.classList.remove("hidden");
          }
          return;
        }
      }

      const variantSuffix = [selectedSize, selectedColorId !== null ? `c${selectedColorId}` : ""]
        .filter(Boolean)
        .join("_");
      const idToCart = variantSuffix ? `${id}__${variantSuffix}` : id;
      const nameToCart = selectedSize
        ? `${name.innerText} (Talle ${selectedSize})`
        : name.innerText;

      addToCart(
        idToCart,
        nameToCart,
        price.innerText.replace("$", "").replace(",", "."),
        qty,
        img?.src ?? "",
          selectedColorId,
          selectedColorName,
      );

      window.updateCartCount && window.updateCartCount();
      addBtn.textContent = "✓ AGREGADO!";
      addBtn.style.backgroundColor = "#388e3c";
      addBtn.style.borderColor = "#388e3c";
      setTimeout(() => {
        addBtn.textContent = "Agregar al carrito";
        addBtn.style.backgroundColor = "";
        addBtn.style.borderColor = "";
      }, 1200);
    });

    const checkStockBtn = document.getElementById("checkStockBtn") as HTMLButtonElement | null;
    const statusEl = document.getElementById("stockCheckStatus") as HTMLParagraphElement | null;
    const stockBadge = document.getElementById("stockBadge") as HTMLSpanElement | null;
    const priceEl = document.getElementById("productPrice") as HTMLSpanElement | null;

    // Fallback de colores para proveedores sin verificación en vivo (ej: Nuvex).
    // En Martina/Kai la lógica completa vive más abajo junto al checkStock.
    if (!checkStockBtn && !colorSelectionDisabled) {
      const colorsSelector = document.getElementById("colorsSelector");
      const colorNameEl = document.getElementById("colorName");

      const canonicalOrder = ["XS", "S", "M", "L", "XL", "XXL", "XXXL"];

      const normalizeLegacySize = (raw: string): string | null => {
        const token = String(raw || "").trim().toUpperCase();
        if (!token) return null;
        const aliasMap: Record<string, string> = {
          P: "S",
          S: "S",
          M: "M",
          G: "L",
          L: "L",
          GG: "XL",
          XG: "XL",
          XL: "XL",
          XXL: "XXL",
          XXXL: "XXXL",
          XS: "XS",
        };
        return aliasMap[token] || null;
      };

      const cleanColorLabel = (raw: string): string => {
        return String(raw || "")
          .replace(/\b(XXXL|XXL|XL|XS|GG|XG|G|M|P|S|L)\b/gi, " ")
          .replace(/\b\d{6,}\b/g, " ")
          .replace(/[\s_-]{2,}/g, " ")
          .replace(/\s+/g, " ")
          .trim();
      };

      const extractNuvexSizeFromColorName = (raw: string): string | null => {
        const token = String(raw || "").toUpperCase();
        const match = token.match(/\b(XXXL|XXL|XL|XS|GG|XG|G|M|P|S|L)\b/);
        if (!match) return null;
        return normalizeLegacySize(match[1]);
      };

      const extractDescriptionSizes = (rawText: string): string[] => {
        const found = new Set<string>();
        const source = String(rawText || "");
        const tallaRegex = /\btalle\s*[:\-]?\s*([a-zA-Z]{1,4}|\d{1,3})\b/gi;
        let m: RegExpExecArray | null;
        while ((m = tallaRegex.exec(source)) !== null) {
          const normalized = normalizeLegacySize(m[1]);
          if (normalized) found.add(normalized);
        }
        return canonicalOrder.filter((size) => found.has(size));
      };

      const renderNormalizedSizesForFallback = (sizes: string[]) => {
        if (!sizesSelector || sizes.length === 0) return;
        sizesSelector.innerHTML = "";
        sizes.forEach((size) => {
          const button = document.createElement("button");
          button.type = "button";
          button.className = "size";
          button.dataset.size = size;
          button.textContent = size;
          sizesSelector.appendChild(button);
        });
        clearSelectedSize();
      };

      const markUnavailableSizesForFallback = (availableSet: Set<string>) => {
        if (!sizesSelector) return;
        sizesSelector
          .querySelectorAll<HTMLButtonElement>(".size")
          .forEach((btn) => {
            const sz = btn.dataset.size || "";
            const isAvailable = availableSet.has(sz);
            btn.classList.toggle("unavailable", !isAvailable);
            btn.disabled = !isAvailable;
            if (!isAvailable) btn.classList.remove("selected");
          });
      };

      if (colorsSelector && colorsSelector.dataset.bound !== "true") {
        colorsSelector.dataset.bound = "true";

        availableSizesByColor.clear();
        colorsSelector
          .querySelectorAll<HTMLButtonElement>(".swatch")
          .forEach((sw) => {
            const cid = Number(sw.dataset.colorId);
            if (!Number.isFinite(cid)) return;
            const rawName = sw.dataset.colorName || "";
            const cleanedName = cleanColorLabel(rawName);
            if (cleanedName) sw.dataset.colorName = cleanedName;
            let hasSizesFromPayload = false;
            try {
              const parsedSizes = JSON.parse(sw.dataset.colorSizes || "[]");
              if (Array.isArray(parsedSizes)) {
                parsedSizes
                  .map((sizeToken) => normalizeLegacySize(String(sizeToken || "")))
                  .filter((size): size is string => Boolean(size))
                  .forEach((size) => {
                    if (!availableSizesByColor.has(cid)) {
                      availableSizesByColor.set(cid, new Set<string>());
                    }
                    availableSizesByColor.get(cid)?.add(size);
                    hasSizesFromPayload = true;
                  });
              }
            } catch {
              hasSizesFromPayload = false;
            }
            const hintedSize = extractNuvexSizeFromColorName(rawName);
            if (!hasSizesFromPayload && hintedSize) {
              if (!availableSizesByColor.has(cid)) {
                availableSizesByColor.set(cid, new Set<string>());
              }
              availableSizesByColor.get(cid)?.add(hintedSize);
            }
          });

        const applySelectedColorAvailability = () => {
          if (!sizesSelector || !requiresSizeSelection) return;
          if (selectedColorId === null) return;
          const availableForColor = availableSizesByColor.get(selectedColorId);
          if (!availableForColor || availableForColor.size === 0) {
            sizesSelector
              .querySelectorAll<HTMLButtonElement>(".size")
              .forEach((btn) => {
                btn.classList.remove("unavailable");
                btn.disabled = false;
              });
            return;
          }
          markUnavailableSizesForFallback(availableForColor);
        };

        // Aplicar disponibilidad de talles del primer color al cargar la página
        {
          const firstSw = colorsSelector.querySelector<HTMLButtonElement>(".swatch");
          if (firstSw) {
            const cid = Number(firstSw.dataset.colorId);
            if (Number.isFinite(cid)) {
              selectedColorId = cid;
              applySelectedColorAvailability();
            }
          }
        }

        const selectColor = (sw: HTMLButtonElement) => {
          const cid = Number(sw.dataset.colorId);
          if (Number.isFinite(cid)) selectedColorId = cid;
          const cleanedName = cleanColorLabel(sw.dataset.colorName || "");
          if (cleanedName) sw.dataset.colorName = cleanedName;
          selectedColorName = cleanedName || sw.dataset.colorName || null;
          if (colorNameEl) colorNameEl.textContent = selectedColorName || "";

          colorsSelector
            .querySelectorAll<HTMLButtonElement>(".swatch")
            .forEach((item) => item.classList.toggle("selected", item === sw));

          applySelectedColorAvailability();
          clearSelectedSize();
          sizeFeedback?.classList.add("hidden");

          try {
            const raw = sw.dataset.colorImages;
            if (!raw) return;
            const parsed = JSON.parse(raw);
            if (Array.isArray(parsed) && parsed.length > 0) {
              window.dispatchEvent(
                new CustomEvent("product:image-set", {
                  detail: { images: parsed.filter(Boolean) },
                }),
              );
            }
          } catch {
            /* noop */
          }
        };

        colorsSelector.addEventListener("click", (event) => {
          const target = event.target as HTMLElement;
          const sw = target.closest(".swatch") as HTMLButtonElement | null;
          if (!sw) return;
          selectColor(sw);
        });

        const firstSwatch = colorsSelector.querySelector<HTMLButtonElement>(".swatch");
        if (firstSwatch) {
          selectColor(firstSwatch);
        }

        const descriptionSource =
          (document.querySelector(".desc-content") as HTMLElement | null)?.textContent ||
          (document.querySelector(".description-box") as HTMLElement | null)?.textContent ||
          "";
        const descriptionSizes = extractDescriptionSizes(descriptionSource);
        const colorHintSizes = new Set<string>();
        availableSizesByColor.forEach((set) => {
          set.forEach((size) => colorHintSizes.add(size));
        });

        const inferredSizes =
          descriptionSizes.length > 1
            ? descriptionSizes
            : canonicalOrder.filter((size) => colorHintSizes.has(size));
        const hasSelectableSizes = inferredSizes.length > 1;
        setSizeRequirement(hasSelectableSizes);
        if (hasSelectableSizes) {
          renderNormalizedSizesForFallback(inferredSizes);
          applySelectedColorAvailability();
        }
      }
    }

    if (checkStockBtn && statusEl && stockBadge && priceEl) {
      const providerLink = checkStockBtn.dataset.providerLink ?? "";
      const martinaCodeValue = checkStockBtn.dataset.martinaCode ?? "202605";
      const martinaCountryIdValue = checkStockBtn.dataset.martinaCountryId ?? "598";

      const normalizeSize = (rawSize: string): string | null => {
        const map: Record<string, string> = {
          "0": "XS",
          "1": "S",
          "2": "M",
          "3": "L",
          "4": "XL",
          "5": "XXL",
          "40": "S",
          "42": "M",
          "44": "L",
          "46": "XL",
          "48": "XXL",
          "50": "XXXL",
          XS: "XS",
          P: "S",
          S: "S",
          M: "M",
          G: "L",
          GG: "XL",
          XG: "XL",
          L: "L",
          XL: "XL",
          XXL: "XXL",
          XXXL: "XXXL",
        };

        const token = rawSize.toUpperCase().replace(/\s+/g, "").trim();
        if (!token) return null;
        if (map[token]) return map[token];

        const parts = token.split("/");
        for (const part of parts) {
          if (map[part]) return map[part];
        }

        const matches = token.match(/(XXXL|XXL|XL|XS|S|M|L|50|48|46|44|42|40|[0-5])/g);
        if (!matches) return null;
        for (const match of matches) {
          if (map[match]) return map[match];
        }

        return null;
      };

      const normalizeSizes = (rawSizes: string[]) => {
        const canonicalOrder = ["XS", "S", "M", "L", "XL", "XXL", "XXXL"];
        const values = new Set<string>();

        rawSizes.forEach((raw) => {
          const normalized = normalizeSize(raw);
          if (normalized) values.add(normalized);
        });

        return canonicalOrder.filter((size) => values.has(size));
      };

      const hasExplicitNoSize = (rawSizes: string[]) => {
        return rawSizes.some((raw) => {
          const token = String(raw ?? "").trim().toLowerCase();
          return token === "/" || token === "-" || token === "sin talle" || token === "unico" || token === "único" || token === "one size";
        });
      };

      const providerFrom = (id: string, link: string): "martina" | "nuvex" | "kaideco" | "alondra" | "unknown" => {
        const idLower = id.toLowerCase();
        const linkLower = link.toLowerCase();

        if (idLower.startsWith("mdt-")) return "martina";
        if (idLower.startsWith("kai-") || linkLower.includes("kaideco.uy")) return "kaideco";
        if (idLower.startsWith("alo-") || linkLower.includes("alondra.com.uy") || linkLower.includes("alondra-ecommerce")) return "alondra";
        if (linkLower.includes("nuvex.uy")) return "nuvex";
        return "unknown";
      };

      const providerMultiplier = {
        martina: 1,
        nuvex: 1.4,
        kaideco: 1.2,
        alondra: 1.22,
        unknown: 1,
      } as const;

      const parseLoosePrice = (rawPrice: unknown): number => {
        const value = String(rawPrice ?? "")
          .trim()
          .replace(/\s+/g, "")
          .replace(/[^\d,.-]/g, "");

        if (!value) return 0;

        const hasComma = value.includes(",");
        const hasDot = value.includes(".");

        if (hasComma && hasDot) {
          return Number(value.replace(/\./g, "").replace(",", "."));
        }

        if (hasComma) {
          return Number(value.replace(",", "."));
        }

        if (hasDot) {
          const parts = value.split(".");
          const looksLikeThousands =
            parts.length > 1 && parts.slice(1).every((part) => part.length === 3);

          if (looksLikeThousands) {
            return Number(parts.join(""));
          }
        }

        return Number(value);
      };

      const applyProviderMarkup = (
        rawPrice: unknown,
        provider: "martina" | "nuvex" | "kaideco" | "alondra" | "unknown",
      ): string => {
        const base = parseLoosePrice(rawPrice);
        if (!Number.isFinite(base) || base <= 0) return "";

        const multiplier = providerMultiplier[provider] ?? 1;
        const adjusted = Math.round(base * multiplier);
        return adjusted.toLocaleString("es-UY");
      };

      const setStatus = (message: string, tone: "ok" | "error" | "neutral" = "neutral") => {
        statusEl.textContent = message;
        statusEl.classList.remove("is-ok", "is-error");
        if (tone === "ok") statusEl.classList.add("is-ok");
        if (tone === "error") statusEl.classList.add("is-error");
      };

      const renderNormalizedSizes = (sizes: string[]) => {
        if (!sizesSelector || sizes.length === 0) return;

        sizesSelector.innerHTML = "";
        sizes.forEach((size) => {
          const button = document.createElement("button");
          button.type = "button";
          button.className = "size";
          button.dataset.size = size;
          button.textContent = size;
          sizesSelector.appendChild(button);
        });
        clearSelectedSize();
      };

      // --- colores + talles disponibles ---
      const colorsBlock = document.getElementById("colorsBlock");
      const colorsSelector = document.getElementById("colorsSelector");
      const colorNameEl = document.getElementById("colorName");

      const markUnavailableSizes = (availableSet: Set<string>) => {
        if (!sizesSelector) return;
        sizesSelector
          .querySelectorAll<HTMLButtonElement>(".size")
          .forEach((btn) => {
            const sz = btn.dataset.size || "";
            const isAvailable = availableSet.has(sz);
            btn.classList.toggle("unavailable", !isAvailable);
            btn.disabled = !isAvailable;
            if (!isAvailable) btn.classList.remove("selected");
          });
      };

      const applyColorSelection = (colorId: number) => {
        selectedColorId = colorId;
        const set = availableSizesByColor.get(colorId) ?? new Set<string>();
        markUnavailableSizes(set);
        clearSelectedSize();
        sizeFeedback?.classList.add("hidden");

        // marcar swatch seleccionado y nombre
        let selectedImages: string[] = [];
        if (colorsSelector) {
          colorsSelector
            .querySelectorAll<HTMLButtonElement>(".swatch")
            .forEach((sw) => {
              const isMatch = Number(sw.dataset.colorId) === colorId;
              sw.classList.toggle("selected", isMatch);
              if (isMatch) {
                selectedColorName = sw.dataset.colorName || null;
                if (colorNameEl) colorNameEl.textContent = selectedColorName || "";
                try {
                  const raw = sw.dataset.colorImages;
                  if (raw) {
                    const parsed = JSON.parse(raw);
                    if (Array.isArray(parsed)) selectedImages = parsed.filter(Boolean);
                  }
                } catch {
                  selectedImages = [];
                }
              }
            });
        }

        // Cambiar la galería si tenemos imágenes del color seleccionado
        if (selectedImages.length > 0) {
          window.dispatchEvent(
            new CustomEvent("product:image-set", {
              detail: { images: selectedImages },
            }),
          );
        }
      };

      const renderColors = (
        colors: Array<{ id: number; hex: string; name: string; sizes?: string[] }>,
      ) => {
        if (colorSelectionDisabled) {
          if (colorsBlock) colorsBlock.classList.add("hidden");
          return;
        }
        if (!colorsSelector || !colorsBlock) return;

        // Indexar imágenes previas server-rendered (por id) para preservarlas
        const prevImagesById = new Map<number, string>();
        colorsSelector
          .querySelectorAll<HTMLButtonElement>(".swatch")
          .forEach((sw) => {
            const cid = Number(sw.dataset.colorId);
            const raw = sw.dataset.colorImages;
            if (Number.isFinite(cid) && raw) prevImagesById.set(cid, raw);
          });

        colorsSelector.innerHTML = "";
        colors.forEach((c) => {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "swatch";
          btn.style.backgroundColor = c.hex || "#cccccc";
          btn.dataset.colorId = String(c.id);
          btn.dataset.colorName = c.name;
          btn.dataset.colorSizes = JSON.stringify(Array.isArray(c.sizes) ? c.sizes : []);
          const imagesAttr = prevImagesById.get(c.id);
          if (imagesAttr) btn.dataset.colorImages = imagesAttr;
          btn.title = c.name;
          btn.setAttribute("aria-label", c.name);
          colorsSelector.appendChild(btn);
        });
        colorsBlock.classList.remove("hidden");
      };

      if (colorsSelector && !colorSelectionDisabled) {
        colorsSelector.addEventListener("click", (event) => {
          const target = event.target as HTMLElement;
          const sw = target.closest(".swatch") as HTMLButtonElement | null;
          if (!sw) return;
          const colorId = Number(sw.dataset.colorId);
          if (Number.isFinite(colorId)) applyColorSelection(colorId);
        });

        // Si hay swatches pre-renderizados desde el server (CSV), aplicar el primero
        const firstSwatch = colorsSelector.querySelector<HTMLButtonElement>(".swatch");
        if (firstSwatch) {
          const cid = Number(firstSwatch.dataset.colorId);
          if (Number.isFinite(cid)) {
            selectedColorId = cid;
            selectedColorName = firstSwatch.dataset.colorName || null;
            if (colorNameEl) colorNameEl.textContent = selectedColorName || "";
            // Sólo para productos Nuvex disparamos el cambio de galería al cargar
            // (cada color suele tener su propio set de fotos). Para Martina/Kai
            // dejamos intacta la galería completa que ya armó el SSR para no
            // recortar el carrusel cuando el usuario aún no eligió color.
            const productIdForInit =
              document.getElementById("addToCartBtn")?.getAttribute("data-id") || "";
            const pidLower = productIdForInit.toLowerCase();
            const isNuvexProduct =
              !pidLower.startsWith("mdt-")
              && !pidLower.startsWith("kai-")
              && !pidLower.startsWith("alo-");
            if (isNuvexProduct) {
              try {
                const raw = firstSwatch.dataset.colorImages;
                if (raw) {
                  const parsed = JSON.parse(raw);
                  if (Array.isArray(parsed) && parsed.length > 0) {
                    window.dispatchEvent(
                      new CustomEvent("product:image-set", {
                        detail: { images: parsed.filter(Boolean) },
                      }),
                    );
                  }
                }
              } catch {
                /* noop */
              }
            }
          }
        }

        // Si no hay swatches pre-renderizados y es producto Martina, intentar inferir colores desde las imágenes
        if (!firstSwatch) {
          try {
            const addBtnEl = document.getElementById("addToCartBtn");
            const productIdAttr = addBtnEl?.getAttribute("data-id") || '';
            if (productIdAttr.toLowerCase().startsWith('mdt-')) {
              const imagesDataEl = document.getElementById('productImagesData');
              const raw = imagesDataEl?.getAttribute('data-images') || '[]';
              const parsedImgs = JSON.parse(raw);
              const imgs: string[] = Array.isArray(parsedImgs)
                ? parsedImgs.filter((value): value is string => typeof value === "string")
                : [];
              const grouped = new Map();
              imgs.forEach((u) => {
                try {
                  const fname = u.split('/').pop() || '';
                  const m = fname.match(/^[0-9]+_(\d+)_\d+\.[a-zA-Z]{3,4}$/);
                  const colorId = m ? Number(m[1]) : null;
                  const key = colorId !== null && Number.isFinite(colorId) ? String(colorId) : '0';
                  if (!grouped.has(key)) grouped.set(key, []);
                  grouped.get(key).push(u);
                } catch {
                  // ignore
                }
              });

              const inferredColors = Array.from(grouped.entries())
                .filter(([k]) => k !== undefined)
                .map(([k, arr]) => ({ id: Number(k), hex: '#cccccc', name: `Color ${k}`, images: arr }));

              if (inferredColors.length > 0) {
                renderColors(inferredColors);
                const first = inferredColors[0];
                selectedColorId = first.id;
                applyColorSelection(first.id);
              }
            }
          } catch (e) {
            // noop
          }
        }
      }

      const fetchMartinaLive = async (productId: string) => {
        const productIdNumber = productId.replace(/^mdt-/i, "");
        const endpoint = new URL("https://pol21.martinaditrento.com/mdt-services/resources/store/product");
        endpoint.searchParams.set("productId", productIdNumber);
        endpoint.searchParams.set("code", martinaCodeValue);
        endpoint.searchParams.set("countryId", martinaCountryIdValue);

        const controller = new AbortController();
        const timeout = window.setTimeout(() => controller.abort(), 6000);
        try {
          const response = await fetch(endpoint.toString(), {
            cache: "no-store",
            signal: controller.signal,
            headers: {
              Accept: "application/json, text/plain, */*",
            },
          });

          if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
          }

          const payload = await response.json();
          const dataArray: any[] = Array.isArray(payload?.data) ? payload.data : [];

          // data vacío => sin stock disponible en el proveedor
          if (dataArray.length === 0) {
            return {
              provider: "martina" as const,
              price: "",
              inStock: false,
              colors: [] as Array<{ id: number; hex: string; name: string; sizes: string[]; rawSizes: string[] }>,
              sizes: [] as string[],
            };
          }

          const colorMap = new Map<
            number,
            { id: number; hex: string; name: string; rawSizes: Set<string> }
          >();

          dataArray.forEach((entry) => {
            const tipoVentas = entry?.variation?.variationValues ?? [];
            tipoVentas.forEach((tv: any) => {
              const colorVariations = tv?.variation?.variationValues ?? [];
              colorVariations.forEach((color: any) => {
                const colorId = Number(color?.id);
                if (!Number.isFinite(colorId)) return;
                if (!colorMap.has(colorId)) {
                  colorMap.set(colorId, {
                    id: colorId,
                    hex: String(color?.colorHex ?? "#cccccc"),
                    name: String(color?.description ?? "").trim(),
                    rawSizes: new Set<string>(),
                  });
                }
                const sizeVariations = color?.variation?.variationValues ?? [];
                sizeVariations.forEach((sz: any) => {
                  const desc = String(sz?.description ?? "").trim();
                  if (desc) colorMap.get(colorId)!.rawSizes.add(desc);
                });
              });
            });
          });

          const colors = Array.from(colorMap.values()).map((c) => ({
            id: c.id,
            hex: c.hex,
            name: c.name,
            rawSizes: Array.from(c.rawSizes),
            sizes: normalizeSizes(Array.from(c.rawSizes)),
          }));

          const allSizes = normalizeSizes(
            colors.flatMap((c) => c.rawSizes),
          );

          const firstEntry = dataArray[0] ?? {};

          return {
            provider: "martina" as const,
            price: String(firstEntry?.price ?? "").trim(),
            inStock: colors.some((c) => c.sizes.length > 0),
            colors,
            sizes: allSizes,
          };
        } finally {
          window.clearTimeout(timeout);
        }
      };

      const formatKaiPrice = (raw: unknown) => {
        const value = Number(raw);
        if (Number.isNaN(value)) return "";
        const normalized = value >= 100 ? Math.trunc(value / 100) : Math.trunc(value);
        return normalized.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
      };

      const extractKaiRawSizes = (product: any): string[] => {
        const variants = Array.isArray(product?.variants) ? product.variants : [];
        const options = Array.isArray(product?.options) ? product.options : [];
        const sizeOptionIndex = options.findIndex((option: any) => {
          const name = String(option?.name ?? "").toLowerCase();
          return name.includes("talle") || name.includes("size");
        });

        const candidateValues: string[] = [];

        variants.forEach((variant: any) => {
          if (!variant?.available) return;

          if (sizeOptionIndex >= 0) {
            const optionValue = variant?.[`option${sizeOptionIndex + 1}`];
            if (optionValue) candidateValues.push(String(optionValue));
          }

          if (variant?.title) {
            candidateValues.push(String(variant.title));
          }
        });

        return candidateValues;
      };

      const fetchKaiLive = async (providerUrl: string) => {
        const productUrl = new URL(providerUrl);
        const segments = productUrl.pathname.split("/").filter(Boolean);
        const productsIndex = segments.findIndex((segment) => segment === "products");
        const handle = productsIndex >= 0 ? segments[productsIndex + 1] : "";

        if (!handle) {
          throw new Error("No se pudo detectar handle de Kai");
        }

        const endpoint = `https://kaideco.uy/products/${handle}.js`;
        const controller = new AbortController();
        const timeout = window.setTimeout(() => controller.abort(), 6000);

        try {
          const response = await fetch(endpoint, {
            cache: "no-store",
            signal: controller.signal,
            headers: {
              Accept: "application/json",
            },
          });

          if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
          }

          const product = await response.json();
          const variants = Array.isArray(product?.variants) ? product.variants : [];
          const firstVariant = variants[0] ?? null;
          const rawSizes = extractKaiRawSizes(product);

          return {
            provider: "kaideco",
            price: formatKaiPrice(firstVariant?.price ?? product?.price),
            inStock: variants.length > 0 ? variants.some((variant: any) => Boolean(variant?.available)) : null,
            sizes: normalizeSizes(rawSizes),
          };
        } finally {
          window.clearTimeout(timeout);
        }
      };

      const fetchNuvexLive = async (providerUrl: string) => {
        if (!providerUrl || !providerUrl.toLowerCase().includes("nuvex.uy")) {
          return {
            provider: "nuvex" as const,
            price: "",
            inStock: null,
            source: "nuvex-web",
          };
        }

        const endpointPath = `${String(document.documentElement.dataset.basePath || "").replace(/\/+$/, "")}/api/provider-nuvex`;
        const endpoint = new URL(endpointPath, window.location.origin);
        endpoint.searchParams.set("url", providerUrl);

        const controller = new AbortController();
        const timeout = window.setTimeout(() => controller.abort(), 7000);

        try {
          const response = await fetch(endpoint.toString(), {
            cache: "no-store",
            signal: controller.signal,
            headers: {
              Accept: "application/json",
            },
          });

          if (!response.ok) {
            return {
              provider: "nuvex" as const,
              price: "",
              inStock: null,
              source: response.status === 404 ? "nuvex-static-no-api" : "nuvex-web",
            };
          }

          const payload = await response.json();
          return {
            provider: "nuvex" as const,
            price: String(payload?.price ?? "").trim(),
            inStock: typeof payload?.inStock === "boolean" ? payload.inStock : null,
            source: String(payload?.source ?? "nuvex-web"),
          };
        } catch {
          return {
            provider: "nuvex" as const,
            price: "",
            inStock: null,
            source: "nuvex-static-no-api",
          };
        } finally {
          window.clearTimeout(timeout);
        }
      };

      const fetchAlondraLive = async (productId: string) => {
        const alondraId = String(productId || "").replace(/^alo-/i, "").trim();
        if (!alondraId) {
          return {
            provider: "alondra" as const,
            price: "",
            inStock: null,
          };
        }

        const endpoint = `https://alondra-ecommerce-be.sitios.uy/api/products/${encodeURIComponent(alondraId)}`;
        const controller = new AbortController();
        const timeout = window.setTimeout(() => controller.abort(), 7000);

        try {
          const response = await fetch(endpoint, {
            cache: "no-store",
            signal: controller.signal,
            headers: {
              Accept: "application/json",
            },
          });

          if (!response.ok) {
            return {
              provider: "alondra" as const,
              price: "",
              inStock: null,
            };
          }

          const payload = await response.json();
          const product = Array.isArray(payload) ? payload[0] : payload;
          const rawPrice = product?.new_price ?? product?.price ?? "";
          const inStock =
            typeof product?.listed === "boolean"
              ? product.listed
              : typeof product?.in_stock === "boolean"
                ? product.in_stock
                : typeof product?.stock === "number"
                  ? product.stock > 0
                  : typeof product?.quantity === "number"
                    ? product.quantity > 0
                    : null;

          return {
            provider: "alondra" as const,
            price: String(rawPrice ?? "").trim(),
            inStock,
          };
        } catch {
          return {
            provider: "alondra" as const,
            price: "",
            inStock: null,
          };
        } finally {
          window.clearTimeout(timeout);
        }
      };

      checkStockBtn.addEventListener("click", async () => {
        const productId = checkStockBtn.dataset.productId ?? "";
        if (!productId) return;

        const originalText = checkStockBtn.textContent;
        checkStockBtn.disabled = true;
        checkStockBtn.textContent = "Verificando...";
        setStatus("Consultando proveedor en vivo...");

        try {
          const provider = providerFrom(productId, providerLink);

          if (provider === "martina") {
            const data = await fetchMartinaLive(productId);

            const nextPrice = applyProviderMarkup(data?.price, provider);
            if (nextPrice) {
              priceEl.textContent = `$${nextPrice}`;
            }

            // sin colores => producto sin stock disponible
            if (!data || data.colors.length === 0) {
              stockBadge.textContent = "Sin stock";
              stockBadge.style.background = "#a33a3a";
              availableSizesByColor.clear();
              selectedColorId = null;
              if (sizesSelector) {
                sizesSelector
                  .querySelectorAll<HTMLButtonElement>(".size")
                  .forEach((btn) => {
                    btn.classList.add("unavailable");
                    btn.classList.remove("selected");
                    btn.disabled = true;
                  });
              }
              if (colorsBlock) colorsBlock.classList.add("hidden");
              setStatus(
                "Este producto puede no tener stock disponible en el proveedor.",
                "error",
              );
              return;
            }

            stockBadge.textContent = "En Stock";
            stockBadge.style.background = "#27ae60";

            availableSizesByColor.clear();
            data.colors.forEach((c) => {
              availableSizesByColor.set(c.id, new Set(c.sizes));
            });

            const allRawSizes = data.colors.flatMap((c) => c.rawSizes || []);
            const allNormalizedSizes = data.colors.flatMap((c) => c.sizes || []);
            const shouldSkipSize = allNormalizedSizes.length === 0 && hasExplicitNoSize(allRawSizes);
            setSizeRequirement(!shouldSkipSize);

            renderColors(data.colors);

            // seleccionar primer color y aplicar sus talles
            const firstColor = data.colors[0];
            selectedColorId = firstColor.id;
            if (!shouldSkipSize) {
              applyColorSelection(firstColor.id);
            }

            setStatus("Actualizado desde martina.", "ok");
          } else if (provider === "kaideco") {
            const data = await fetchKaiLive(providerLink);

            const nextPrice = applyProviderMarkup(data?.price, provider);
            if (nextPrice) {
              priceEl.textContent = `$${nextPrice}`;
            }

            if (data?.inStock === true) {
              stockBadge.textContent = "En Stock";
              stockBadge.style.background = "#27ae60";
            } else if (data?.inStock === false) {
              stockBadge.textContent = "Sin stock";
              stockBadge.style.background = "#a33a3a";
            }

            const normalizedSizes = Array.isArray(data?.sizes)
              ? data.sizes.filter(Boolean)
              : [];

            if (normalizedSizes.length > 0) {
              setSizeRequirement(true);
              renderNormalizedSizes(normalizedSizes);
              availableSizesByColor.clear();
              availableSizesByColor.set(-1, new Set(normalizedSizes));
              selectedColorId = -1;
              markUnavailableSizes(new Set(normalizedSizes));
            } else {
              setSizeRequirement(false);
            }

            setStatus("Actualizado desde kaideco.", "ok");
          } else if (provider === "nuvex") {
            const data = await fetchNuvexLive(providerLink);

            if (data?.inStock === true) {
              stockBadge.textContent = "En Stock";
              stockBadge.style.background = "#27ae60";
              setStatus("Stock verificado en Nuvex. El precio se mantiene según catálogo.", "ok");
            } else if (data?.inStock === false) {
              stockBadge.textContent = "Sin stock";
              stockBadge.style.background = "#a33a3a";
              setStatus("Sin stock en Nuvex. El precio se mantiene según catálogo.", "error");
            } else if (data?.source === "nuvex-static-no-api") {
              setStatus(
                "En GitHub Pages no se puede verificar Nuvex en vivo (hosting estático + CORS). Se mantiene stock de catálogo.",
              );
            } else {
              setStatus("Ten presente que puede ser que este producto no este disponible.");
            }
          } else if (provider === "alondra") {
            const data = await fetchAlondraLive(productId);

            const nextPrice = applyProviderMarkup(data?.price, provider);
            if (nextPrice) {
              priceEl.textContent = `$${nextPrice}`;
            }

            if (data?.inStock === true) {
              stockBadge.textContent = "En Stock";
              stockBadge.style.background = "#27ae60";
              setStatus("Stock y precio actualizados desde Alondra.", "ok");
            } else if (data?.inStock === false) {
              stockBadge.textContent = "Sin stock";
              stockBadge.style.background = "#a33a3a";
              setStatus("Sin stock en Alondra. Precio actualizado si estuvo disponible.", "error");
            } else {
              setStatus("No se pudo confirmar stock en Alondra. Precio actualizado si hubo respuesta.");
            }
          } else {
            setStatus(
              "Este proveedor no soporta verificacion en vivo desde esta pagina estatica.",
              "error",
            );
          }
        } catch (error) {
          setStatus("No se pudo verificar ahora. Se mantiene informacion estatica.", "error");
        } finally {
          checkStockBtn.disabled = false;
          checkStockBtn.textContent = originalText || "Verificar stock y precio";
        }
      });

      // Auto-verificar al cargar la página (solo para productos con proveedor soportado)
      const autoProvider = providerFrom(
        checkStockBtn.dataset.productId ?? "",
        providerLink,
      );
      if (
        autoProvider === "martina"
        || autoProvider === "kaideco"
        || autoProvider === "nuvex"
        || autoProvider === "alondra"
      ) {
        // requestIdleCallback si está disponible, sino timeout corto
        const trigger = () => checkStockBtn.click();
        const w = window as any;
        if (typeof w.requestIdleCallback === "function") {
          w.requestIdleCallback(trigger, { timeout: 1500 });
        } else {
          w.setTimeout(trigger, 300);
        }
      }
    }

  // Solo para Nuvex enviamos set inicial manual a la galería.
  // Para Martina/Kai dejamos el render SSR original sin tocar.
  const globalProductId = addBtn?.getAttribute("data-id") || "";
  const globalPidLower = globalProductId.toLowerCase();
  const globalIsNuvex =
    !globalPidLower.startsWith("mdt-")
    && !globalPidLower.startsWith("kai-")
    && !globalPidLower.startsWith("alo-");

  if (globalIsNuvex) {
    try {
      const imagesDataEl = document.getElementById("productImagesData");
      if (imagesDataEl) {
        const raw = imagesDataEl.getAttribute("data-images") || "[]";
        const parsed = JSON.parse(raw);
        if (Array.isArray(parsed) && parsed.length > 0) {
          window.dispatchEvent(
            new CustomEvent("product:image-set", {
              detail: { images: parsed.filter(Boolean) },
            }),
          );
        }
      }
    } catch {
      /* noop */
    }

    // Reintento para cubrir hidratación tardía de la isla.
    setTimeout(() => {
      try {
        const imagesDataEl = document.getElementById("productImagesData");
        if (!imagesDataEl) return;
        const raw = imagesDataEl.getAttribute("data-images") || "[]";
        const parsed = JSON.parse(raw);
        if (Array.isArray(parsed) && parsed.length > 0) {
          window.dispatchEvent(
            new CustomEvent("product:image-set", {
              detail: { images: parsed.filter(Boolean) },
            }),
          );
        }
      } catch {
        /* noop */
      }
    }, 350);
  }
}
document.addEventListener("astro:page-load", initProductDetail);
</script>
