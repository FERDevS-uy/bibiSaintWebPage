---
import { config } from "../config";
import Layout from "../layouts/Layout.astro";
import { withBasePath } from "@utils/basePath";
import styles from "../styles/pages/carrito.module.css";
import "../styles/components/CartDynamic.css";

export const prerender = true;
const pathname = Astro.url.pathname;
---

<Layout>
  <section class={styles.cartContainer}>
    <div class={styles.cartHeader}>
      <h1>Mi Compra</h1>
      <div class={styles.headerSeparator}></div>
      <p>Productos en su carrito</p>
    </div>

    <!-- Tabla de productos -->
    <table id="cartTable" class={`${styles.cartTable} hidden`}>
      <thead>
        <tr>
          <th></th>
          <th>Producto</th>
          <th>Descripción</th>
          <th>Cantidad</th>
          <th>Subtotal</th>
        </tr>
      </thead>
      <tbody id="cartList"></tbody>
    </table>

    <!-- Resumen -->
    <div id="cartSummary" class={`${styles.cartSummary} hidden`}>
      <h2>Resumen de su compra</h2>

      <!-- Subtotal removed as requested -->

      <button id="clearBtn" class={`${styles.cartBtn} ${styles.danger}`}
        >Vaciar Carrito</button
      >
      <a href={withBasePath("/", pathname)} class={`${styles.cartBtn} ${styles.secondary}`}
        >Seguir Comprando</a
      >

      <div class={styles.cartSummaryTotal}>
        <span>Total:</span>
        <span id="total">$0</span>
      </div>

      <p class={styles.whatsAppHint}>
        Finalize su compra enviando el pedido por WhatsApp
      </p>

      <a
        id="waBtn"
        class={`${styles.cartBtn} ${styles.whatsapp}`}
        target="_blank"
      >
        <span class={styles.waBtnContent}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true">
            <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21 5.46 0 9.91-4.45 9.91-9.91C22 6.45 17.5 2 12.04 2zm0 18.16c-1.56 0-3.08-.42-4.4-1.21l-.32-.19-3.12.82.83-3.04-.21-.33a8.18 8.18 0 0 1-1.27-4.3c0-4.54 3.69-8.23 8.24-8.23s8.23 3.69 8.23 8.23-3.69 8.25-8.23 8.25zm4.52-6.16c-.25-.12-1.47-.72-1.69-.8-.23-.08-.39-.12-.56.12-.17.25-.64.8-.79.97-.14.17-.29.19-.54.07-.25-.12-1.05-.39-2-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42-.14 0-.31-.02-.47-.02-.16 0-.43.06-.66.31-.22.25-.87.85-.87 2.07s.9 2.4 1.02 2.56c.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.47-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.23-.17-.48-.29z"/>
          </svg>
          <strong>Finalizar Compra</strong>
        </span>
      </a>
      <!-- Hidden copy button if needed for logic, but removing from UI -->
      <button id="copyBtn" style="display:none;"></button>
    </div>

    <!-- Carrito vacío -->
    <div id="cartEmpty" class={styles.cartEmpty}>El carrito está vacío.</div>
  </section>
</Layout>

<script>
  import { initCartPage } from "../scripts/pages/carrito";

  // Initialize on load
  initCartPage();

  // Re-initialize for View Transitions
  document.addEventListener("astro:page-load", () => {
    initCartPage();
  });
</script>
