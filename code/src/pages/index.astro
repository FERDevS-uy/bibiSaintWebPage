---
import OfertasBanner from "@components/OfertasBanner.astro";
import Layout from "@layouts/Layout.astro";
import ProductCarousel from "@components/ProductCarousel.astro";
import { loadProducts } from "@utils/loadProducts";
import { ProductListHydrator } from "@stores/ProductListHydrator";

const todosLosProductos = await loadProducts();

// 1. ¡Novedades!: Los últimos 8 productos agregados (en orden inverso)
const novedades = [...todosLosProductos].reverse().slice(0, 8);

// 2. ¡Destacados!: Los primeros 8 productos del catálogo
const destacados = todosLosProductos.slice(0, 8);

// 3. ¡Ofertas!: Productos marcados con enOferta = true, con fallback
let ofertas = todosLosProductos.filter(p => p.enOferta);
if (ofertas.length < 4) {
  const fallbacks = todosLosProductos.filter(p => !p.enOferta).slice(0, 8 - ofertas.length);
  ofertas = [...ofertas, ...fallbacks];
} else {
  ofertas = ofertas.slice(0, 8);
}

const hydratorProducts = [...new Set([...novedades, ...destacados, ...ofertas])].map(p => ({
  id: p.id,
  name: p.name,
  price: p.price,
  img: p.img[0],
  enOferta: Boolean(p.enOferta),
}));
---

<Layout pageId="index">
  <ProductListHydrator client:load products={hydratorProducts} />
  <OfertasBanner />
  <ProductCarousel products={novedades} title="¡Novedades!" id="novedades" />
  <ProductCarousel products={destacados} title="¡Destacados!" id="destacados" />
  <ProductCarousel products={ofertas} title="¡Ofertas!" id="ofertas" />
</Layout>
