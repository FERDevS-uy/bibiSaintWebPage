---
import Layout from "@layouts/Layout.astro";
import ListarProductos from "@components/ListarProductos.astro";
import { cargarProductos } from "@utils/loadCSV";
import { parsePrice } from "@utils/price";
import { config } from "src/config";

export const prerender = true;

const topBaratos = [...cargarProductos()]
  .map((product) => ({
    product,
    numericPrice: parsePrice(product.price),
  }))
  .filter(({ numericPrice }) => Number.isFinite(numericPrice) && numericPrice > 0)
  .sort((a, b) => {
    if (a.numericPrice !== b.numericPrice) return a.numericPrice - b.numericPrice;
    return a.product.name.localeCompare(b.product.name, "es", { sensitivity: "base" });
  })
  .slice(0, 50)
  .map(({ product }) => product);

const productsPerPage = config.postPerPage;
const totalPages = Math.ceil(topBaratos.length / productsPerPage);
const products = topBaratos.slice(0, productsPerPage);
const offersBaseUrl = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/ofertas`;
---

<Layout pageTitle="Bibi's - Ofertas" pageId="offers">
  <section class="offersHeader">
    <span class="offersBadge">Precio bajo asegurado</span>
    <h1>Ofertas destacadas</h1>
    <p>Top 50 productos más baratos del catálogo, ordenados de menor a mayor precio.</p>
    <div class="offersMeta">
      <span>{topBaratos.length} productos</span>
      <span>{totalPages} páginas</span>
    </div>
  </section>

  <ListarProductos
    products={products}
    totalPages={totalPages}
    actualPage={1}
    baseURL={offersBaseUrl}
  />
</Layout>

<style>
  .offersHeader {
    width: min(1040px, 94%);
    margin: 1.4rem auto 0.9rem;
    padding: clamp(1rem, 2.5vw, 1.5rem);
    text-align: center;
    border-radius: 16px;
    border: 1px solid rgba(35, 41, 70, 0.1);
    background:
      radial-gradient(circle at 20% 0%, rgba(210, 232, 255, 0.6), transparent 40%),
      radial-gradient(circle at 80% 100%, rgba(255, 222, 186, 0.6), transparent 38%),
      #ffffff;
    box-shadow: 0 8px 24px rgba(35, 41, 70, 0.08);
  }

  .offersBadge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
    background: #232946;
    color: #fff;
    font-size: 0.73rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .offersHeader h1 {
    margin: 0.55rem 0 0;
    font-size: clamp(1.8rem, 3.6vw, 2.6rem);
    color: var(--principal-text-color);
    line-height: 1.1;
  }

  .offersHeader p {
    margin: 0.5rem auto 0;
    color: #4e577b;
    max-width: 58ch;
    font-size: clamp(0.95rem, 1.6vw, 1.05rem);
  }

  .offersMeta {
    margin-top: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .offersMeta span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 108px;
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(35, 41, 70, 0.18);
    color: #232946;
    font-size: 0.83rem;
    font-weight: 600;
    background: rgba(255, 255, 255, 0.85);
  }

  @media (max-width: 700px) {
    .offersHeader {
      margin-top: 1rem;
      margin-bottom: 0.6rem;
      border-radius: 12px;
      padding: 0.95rem 0.8rem;
    }

    .offersMeta {
      width: 100%;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.45rem;
    }

    .offersMeta span {
      min-width: 0;
      flex: 1 1 auto;
      max-width: 170px;
    }
  }
</style>
