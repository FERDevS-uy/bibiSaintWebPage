---
import ListarProductos from "@components/ListarProductos.astro";
import Layout from "@layouts/Layout.astro";
import { loadProducts } from "@utils/loadProducts";
import { config } from "src/config";

const CANT_PRODUCTOS = config.postPerPage;
const allProducts = await loadProducts();
const { pag } = Astro.params;

const totalPages = Math.ceil(allProducts.length / CANT_PRODUCTOS);
const pageNum = Number(pag);
const start = (pageNum - 1) * CANT_PRODUCTOS;
const products = allProducts.slice(start, start + CANT_PRODUCTOS);
---

<Layout pageId="index">
  <ListarProductos
    products={products}
    totalPages={totalPages}
    actualPage={pag}
  />
</Layout>
