---
import Layout from "@layouts/Layout.astro";
import { config } from "src/config";
---

<Layout pageTitle=`${config.pageTitle} - Pedido`>
  <section class="pedido-container">

    <div class="pedido-header">
      <h1>Pedido recibido</h1>
      <div class="pedido-separator"></div>
      <p>Detalle del pedido del cliente</p>
    </div>

    <div id="result__container"></div>

  </section>
</Layout>

<style>
  .pedido-container {
    max-width: 900px;
    margin: 40px auto;
    padding: 0 20px 60px;
    font-family: "Poppins", Arial, sans-serif;
    color: #222;
  }

  .pedido-header h1 {
    font-size: 2.2rem;
    font-weight: 800;
    margin: 0 0 8px;
    color: #000;
  }

  .pedido-separator {
    width: 90px;
    height: 7px;
    background-color: #d32f2f;
    border-radius: 4px;
    margin-bottom: 8px;
  }

  .pedido-header p {
    font-size: 1rem;
    color: #666;
    margin: 0 0 32px;
  }

  /* ------- Product list ------- */
  :global(.pedido-list) {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }

  :global(.pedido-list-header) {
    display: grid;
    grid-template-columns: 90px 1fr 80px 110px;
    gap: 12px;
    padding: 12px 20px;
    background: #f7f7f7;
    border-bottom: 2px solid #d32f2f;
    font-weight: 700;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #444;
  }

  :global(.pedido-item) {
    display: grid;
    grid-template-columns: 90px 1fr 80px 110px;
    gap: 12px;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid #eee;
    transition: background 0.15s;
  }

  :global(.pedido-item:last-child) {
    border-bottom: none;
  }

  :global(.pedido-item:hover) {
    background: #fafafa;
  }

  :global(.pedido-item img) {
    width: 80px;
    height: 80px;
    object-fit: contain;
    border-radius: 8px;
    background: #f5f5f5;
    display: block;
  }

  :global(.pedido-item-info) {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  :global(.pedido-item-name) {
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.35;
    color: #111;
  }

  :global(.pedido-item-price) {
    font-size: 0.88rem;
    color: #777;
  }

  :global(.pedido-size-badge) {
    display: inline-block;
    background: #d32f2f;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
    letter-spacing: 0.04em;
    width: fit-content;
  }

  :global(.pedido-qty) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #f0f0f0;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.1rem;
    width: 44px;
    height: 44px;
    color: #222;
  }

  :global(.pedido-subtotal) {
    font-weight: 700;
    font-size: 1rem;
    color: #222;
    text-align: right;
  }

  /* ------- Total ------- */
  :global(.pedido-total-box) {
    margin-top: 24px;
    display: flex;
    justify-content: flex-end;
  }

  :global(.pedido-total-inner) {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
    padding: 24px 32px;
    min-width: 280px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  :global(.pedido-total-row) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1rem;
    color: #555;
  }

  :global(.pedido-total-row.main) {
    font-size: 1.4rem;
    font-weight: 800;
    color: #111;
    border-top: 2px solid #d32f2f;
    padding-top: 12px;
    margin-top: 4px;
  }

  :global(.pedido-total-row.main span:last-child) {
    color: #d32f2f;
  }

  /* ------- Error / empty ------- */
  :global(.pedido-message) {
    padding: 48px 0;
    text-align: center;
    font-size: 1.05rem;
    color: #c11010;
    font-weight: 600;
  }

  /* ------- Mobile ------- */
  @media (max-width: 680px) {
    .pedido-header h1 { font-size: 1.7rem; }

    :global(.pedido-list-header) { display: none; }

    :global(.pedido-item) {
      grid-template-columns: 70px 1fr;
      grid-template-rows: auto auto;
      gap: 8px;
      padding: 14px 16px;
    }

    :global(.pedido-item img) {
      width: 70px;
      height: 70px;
      grid-row: 1 / 3;
    }

    :global(.pedido-item-info) { grid-column: 2; }

    :global(.pedido-item .pedido-qty-wrap) {
      grid-column: 2;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    :global(.pedido-total-inner) {
      min-width: unset;
      width: 100%;
    }

    :global(.pedido-total-box) {
      justify-content: stretch;
    }
  }
</style>

<script>
  import { decryptIDs } from "@utils/encription";
  import { formatPrice, parsePrice } from "@utils/price";
  import type Product from "src/types/product";

  const params = new URLSearchParams(window.location.search);
  const idFromQuery = params.get("id");

  interface ProductosDePedido extends Product {
    cantidad: number;
  }

  function parsePedidoItem(item: string): { id: string; cantidad: number } | null {
    const trimmed = item.trim();
    if (!trimmed) return null;

    const separatorIndex = trimmed.lastIndexOf("-");
    if (separatorIndex === -1) return null;

    const rawId = trimmed.slice(0, separatorIndex).trim();
    const rawQty = trimmed.slice(separatorIndex + 1).trim();
    const cantidad = Number(rawQty);

    if (!rawId || Number.isNaN(cantidad)) return null;
    return { id: rawId, cantidad };
  }


  async function fetchProductos(): Promise<Product[]> {
    const urls = [
      `${import.meta.env.BASE_URL}/productos.json`,
      "/productos.json",
      "productos.json",
    ];

    for (const url of urls) {
      try {
        const response = await fetch(url);
        if (response.ok) {
          return (await response.json()) as Product[];
        }
      } catch {
        // Intenta la siguiente ruta
      }
    }

    throw new Error("No se pudo obtener productos.json en ninguna ruta.");
  }

  window.addEventListener("DOMContentLoaded", async () => {
    const id = idFromQuery || localStorage.getItem("lastPedidoToken");

    if (id) {
      const decrypted = decryptIDs(id, "elias");
      const lista = decrypted
        .map(parsePedidoItem)
        .filter((item): item is { id: string; cantidad: number } => Boolean(item));

      try {
        if (lista.length === 0) {
          throw new Error("El enlace de pedido no tiene productos validos.");
        }

        const allProductos = await fetchProductos();

        // El ID en carrito puede tener sufijo __TALLE (ej: mdt-41200__S)
        // Se necesita el ID base (sin sufijo) para buscar en productos.json
        const baseId = (rawId: string) =>
          rawId.includes("__") ? rawId.split("__")[0] : rawId;

        // Iterar desde la lista del carrito para soportar mismo producto con distintos talles
        const productos: ProductosDePedido[] = lista
          .map((listItem) => {
            const bid = baseId(listItem.id);
            const product = allProductos.find((p) => p.id === bid);
            if (!product) return null;
            const sizeSuffix = listItem.id.includes("__")
              ? ` (Talle ${listItem.id.split("__")[1]})`
              : "";
            return { ...product, name: product.name + sizeSuffix, cantidad: listItem.cantidad };
          })
          .filter((p): p is ProductosDePedido => p !== null);

        // result.textContent = JSON.stringify(productos, null, 4);
        renderProducts(productos);
      } catch (e) {
        console.error(e);
        const container = document.getElementById(
          "result__container"
        ) as HTMLDivElement;
        if (container) {
          container.innerHTML = '<p class="pedido-message">No se pudo cargar el pedido. Revisá el enlace e intenta nuevamente.</p>';
        }
      }
    } else {
      const container = document.getElementById(
        "result__container"
      ) as HTMLDivElement;
      if (container) {
        container.innerHTML = '<p class="pedido-message">No hay id de pedido en la URL. Generá uno desde el carrito o abrí un enlace de pedido.</p>';
      }
    }
  });

  function renderProducts(productos: ProductosDePedido[]): void {
    const container = document.getElementById("result__container") as HTMLDivElement;

    const total = productos.reduce(
      (acc, item) => acc + parsePrice(item.price) * item.cantidad,
      0
    );

    // Extraer talle del nombre (formato: "Nombre (Talle X)")
    function parseName(fullName: string): { name: string; size: string | null } {
      const match = fullName.match(/^(.+?)\s*\(Talle\s+(.+?)\)$/);
      if (match) return { name: match[1].trim(), size: match[2] };
      return { name: fullName, size: null };
    }

    const itemsHTML = productos.map((p) => {
      const { name, size } = parseName(p.name);
      const subtotal = formatPrice(parsePrice(p.price) * p.cantidad);
      const sizeBadge = size
        ? `<span class="pedido-size-badge">Talle ${size}</span>`
        : "";
      return `
<div class="pedido-item">
  <img src="${p.img[0]}" alt="${name}" loading="lazy" />
  <div class="pedido-item-info">
    <span class="pedido-item-name">${name}</span>
    ${sizeBadge}
    <span class="pedido-item-price">$${formatPrice(parsePrice(p.price))} c/u</span>
  </div>
  <div class="pedido-qty-wrap">
    <span class="pedido-qty">${p.cantidad}</span>
  </div>
  <div class="pedido-subtotal">$${subtotal}</div>
</div>`;
    }).join("");

    container.innerHTML = `
<div class="pedido-list">
  <div class="pedido-list-header">
    <span></span>
    <span>Producto</span>
    <span style="text-align:center">Cant.</span>
    <span style="text-align:right">Subtotal</span>
  </div>
  ${itemsHTML}
</div>

<div class="pedido-total-box">
  <div class="pedido-total-inner">
    <div class="pedido-total-row">
      <span>${productos.length} ${productos.length === 1 ? "producto" : "productos"}</span>
      <span>${productos.reduce((a, p) => a + p.cantidad, 0)} unidades</span>
    </div>
    <div class="pedido-total-row main">
      <span>Total</span>
      <span>$${formatPrice(total)}</span>
    </div>
  </div>
</div>`;
  }
</script>
