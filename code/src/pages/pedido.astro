---
import Layout from "@layouts/Layout.astro";
import { config } from "src/config";

export const prerender = true;
---

<Layout pageTitle=`${config.pageTitle} - Pedido`>
  <section class="pedido-container">

    <div class="pedido-header">
      <h1>Pedido recibido</h1>
      <div class="pedido-separator"></div>
      <p>Detalle del pedido del cliente</p>
    </div>

    <div id="result__container"></div>

  </section>
</Layout>

<style>
  .pedido-container {
    max-width: 900px;
    margin: 40px auto;
    padding: 0 20px 60px;
    font-family: "Poppins", "Poppins Fallback", Arial, sans-serif;
    color: #222;
  }

  .pedido-header h1 {
    font-size: 2.2rem;
    font-weight: 800;
    margin: 0 0 8px;
    color: #000;
  }

  .pedido-separator {
    width: 90px;
    height: 7px;
    background-color: #d32f2f;
    border-radius: 4px;
    margin-bottom: 8px;
  }

  .pedido-header p {
    font-size: 1rem;
    color: #666;
    margin: 0 0 32px;
  }

  /* ------- Product list ------- */
  :global(.pedido-list) {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }

  :global(.pedido-list-header) {
    display: grid;
    grid-template-columns: 90px 1fr 80px 110px;
    gap: 12px;
    padding: 12px 20px;
    background: #f7f7f7;
    border-bottom: 2px solid #d32f2f;
    font-weight: 700;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #444;
  }

  :global(.pedido-item) {
    display: grid;
    grid-template-columns: 90px 1fr 80px 110px;
    gap: 12px;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid #eee;
    transition: background 0.15s;
  }

  :global(.pedido-item:last-child) {
    border-bottom: none;
  }

  :global(.pedido-item:hover) {
    background: #fafafa;
  }

  :global(.pedido-item img) {
    width: 80px;
    height: 80px;
    object-fit: contain;
    border-radius: 8px;
    background: #f5f5f5;
    display: block;
  }

  :global(.pedido-item-info) {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  :global(.pedido-item-name) {
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.35;
    color: #111;
  }

  :global(.pedido-item-price) {
    font-size: 0.88rem;
    color: #777;
  }

  :global(.pedido-stock-badge) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    border-radius: 999px;
    padding: 3px 10px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  :global(.pedido-stock-badge.pending) {
    background: #ececec;
    color: #555;
  }

  :global(.pedido-stock-badge.ok) {
    background: #27ae60;
    color: #fff;
  }

  :global(.pedido-stock-badge.error) {
    background: #a33a3a;
    color: #fff;
  }

  :global(.pedido-check-row) {
    margin-top: 4px;
  }

  :global(.pedido-check-btn) {
    border: 1px solid #222;
    background: #fff;
    color: #222;
    border-radius: 999px;
    padding: 5px 10px;
    font-size: 0.76rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  :global(.pedido-check-btn:hover) {
    background: #f4f4f4;
  }

  :global(.pedido-check-btn[disabled]) {
    cursor: wait;
    opacity: 0.7;
  }

  :global(.pedido-check-status) {
    margin: 2px 0 0;
    font-size: 0.76rem;
    color: #666;
    line-height: 1.3;
  }

  :global(.pedido-check-status.ok) {
    color: #157f3b;
  }

  :global(.pedido-check-status.error) {
    color: #b42318;
  }

  :global(.pedido-size-badge) {
    display: inline-block;
    background: #d32f2f;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
    letter-spacing: 0.04em;
    width: fit-content;
  }

  :global(.pedido-variant-badge) {
    display: inline-block;
    background: #4d4d4d;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
    letter-spacing: 0.04em;
    width: fit-content;
  }

  :global(.pedido-color-badge) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #f0f0f0;
    color: #222;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 3px 10px 3px 4px;
    border-radius: 20px;
    letter-spacing: 0.04em;
    width: fit-content;
    border: 1px solid #d8d8d8;
  }

  :global(.pedido-color-swatch) {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.18);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
  }

  :global(.pedido-qty) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #f0f0f0;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.1rem;
    width: 44px;
    height: 44px;
    color: #222;
  }

  :global(.pedido-subtotal) {
    font-weight: 700;
    font-size: 1rem;
    color: #222;
    text-align: right;
  }

  /* ------- Total ------- */
  :global(.pedido-total-box) {
    margin-top: 24px;
    display: flex;
    justify-content: flex-end;
  }

  :global(.pedido-total-inner) {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
    padding: 24px 32px;
    min-width: 280px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  :global(.pedido-total-row) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1rem;
    color: #555;
  }

  :global(.pedido-total-row.main) {
    font-size: 1.4rem;
    font-weight: 800;
    color: #111;
    border-top: 2px solid #d32f2f;
    padding-top: 12px;
    margin-top: 4px;
  }

  :global(.pedido-total-row.main span:last-child) {
    color: #d32f2f;
  }

  /* ------- Error / empty ------- */
  :global(.pedido-message) {
    padding: 48px 0;
    text-align: center;
    font-size: 1.05rem;
    color: #c11010;
    font-weight: 600;
  }

  /* ------- Mobile ------- */
  @media (max-width: 680px) {
    .pedido-header h1 { font-size: 1.7rem; }

    :global(.pedido-list-header) { display: none; }

    :global(.pedido-item) {
      grid-template-columns: 70px 1fr;
      grid-template-rows: auto auto;
      gap: 8px;
      padding: 14px 16px;
    }

    :global(.pedido-item img) {
      width: 70px;
      height: 70px;
      grid-row: 1 / 3;
    }

    :global(.pedido-item-info) { grid-column: 2; }

    :global(.pedido-item .pedido-qty-wrap) {
      grid-column: 2;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    :global(.pedido-total-box) {
      justify-content: stretch;
    }

    :global(.pedido-total-inner) {
      min-width: unset;
      width: 100%;
    }

    :global(.pedido-total-box) {
      justify-content: stretch;
    }
  }
</style>

<script>
  // Base64URL encode/decode inline
  function base64UrlEncode(bytes) {
    let binary = "";
    for (let i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
    const b64 = btoa(binary);
    return b64.replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/, "");
  }
  
  function base64UrlDecode(b64url) {
    let b64 = b64url.replace(/-/g, "+").replace(/_/g, "/");
    const pad = b64.length % 4;
    if (pad) b64 += "=".repeat(4 - pad);
    const binary = atob(b64);
    const out = new Uint8Array(binary.length);
    for (let i = 0; i < binary.length; i++) out[i] = binary.charCodeAt(i);
    return out;
  }
  
  // PRNG xorshift32 inline
  function makePRNG(seed) {
    let x = (seed >>> 0) || 123456789;
    return function next() {
      x ^= (x << 13);
      x ^= (x >>> 17);
      x ^= (x << 5);
      return (x >>> 0);
    };
  }
  
  function seedFromPassword(pw) {
    let h = 2166136261 >>> 0;
    for (let i = 0; i < pw.length; i++) {
      h ^= pw.charCodeAt(i);
      h = Math.imul(h, 16777619) >>> 0;
    }
    h = (h ^ (h >>> 16)) >>> 0;
    return h || 123456789;
  }
  
  // Decrypt inline
  function decryptIDs(token, password) {
    const data = base64UrlDecode(token);
    const seed = seedFromPassword(password);
    const prng = makePRNG(seed);
    const out = new Uint8Array(data.length);
    let val = 0;
    for (let i = 0; i < data.length; i++) {
      if (i % 4 === 0) val = prng();
      out[i] = data[i] ^ ((val >>> ((i % 4) * 8)) & 0xff);
    }
    const json = new TextDecoder().decode(out);
    return JSON.parse(json);
  }
  
  // Price parsing inline
  function parsePrice(priceStr) {
    const cleanStr = String(priceStr).replace(/[^\d.,]/g, "").replace(/\./g, "").replace(",", ".");
    return parseFloat(cleanStr) || 0;
  }
  
  function formatPrice(price) {
    return new Intl.NumberFormat("es-UY", { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(price);
  }

  // Normaliza talles para variantes (XS..XXXL, GG/XG, 0..5, 40..50)
  function normalizeSize(rawSize) {
    const map = {
      "0": "XS", "1": "S", "2": "M", "3": "L", "4": "XL", "5": "XXL",
      "40": "S", "42": "M", "44": "L", "46": "XL", "48": "XXL", "50": "XXXL",
      "XS": "XS", "P": "S", "S": "S", "M": "M",
      "G": "L", "GG": "XL", "XG": "XL",
      "L": "L", "XL": "XL", "XXL": "XXL", "XXXL": "XXXL"
    };
    const token = String(rawSize || "").toUpperCase().replace(/\s+/g, "").trim();
    if (!token) return null;
    if (map[token]) return map[token];
    const parts = token.split("/");
    for (const part of parts) {
      if (map[part]) return map[part];
    }
    const matches = token.match(/(XXXL|XXL|XL|XS|S|M|L|50|48|46|44|42|40|[0-5])/g);
    if (matches) {
      for (const m of matches) {
        if (map[m]) return map[m];
      }
    }
    return null;
  }

  // Parsea "baseId__variant_cN" -> { baseId, variantToken, colorId }
  function parseTokenId(tokenId) {
    const [base, rest = ""] = String(tokenId || "").split("__");
    if (!rest) return { baseId: base, variantToken: null, colorId: null };
    let variant = null;
    let colorId = null;
    rest.split("_").map((p) => p.trim()).filter(Boolean).forEach((part) => {
      const m = part.match(/^c(\d+)$/i);
      if (m) {
        const cid = Number(m[1]);
        if (Number.isFinite(cid)) colorId = cid;
        return;
      }
      if (!variant) variant = part;
    });
    return { baseId: base, variantToken: variant, colorId };
  }

  function isMeasurement(str) {
    const upper = String(str || "").toUpperCase().trim();
    return /(\d+\s*[Xx]\s*\d+)/.test(upper) || /(\d+\s*(CM|MM|M|L|LT|PZA|PZAS|UN|U))/i.test(upper) || /^[A-Z]-\d+$/i.test(upper);
  }

  function variantBadgeText(variantToken) {
    if (!variantToken) return null;
    const upper = String(variantToken).trim().toUpperCase();
    if (!upper) return null;
    const normalized = normalizeSize(upper);
    if (normalized) return `Talle ${normalized}`;
    if (isMeasurement(upper)) return `Medida ${upper}`;
    return `Variante ${upper}`;
  }

  function escapeHtml(str) {
    return String(str ?? "").replace(/[&<>"']/g, (c) => ({
      "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"
    }[c]));
  }

  document.addEventListener("astro:page-load", async () => {
    const params = new URLSearchParams(window.location.search);
    const tokenId = params.get("id");

    if (!tokenId) {
      const el = document.getElementById("result__container");
      if (el) el.innerHTML = '<p class="pedido-message">No hay id de pedido. Generá uno desde el carrito.</p>';
      return;
    }

    try {
      const decrypted = decryptIDs(tokenId, "elias");

      // Fetch productos.json
      const runtimeBasePath = (document.documentElement.dataset.basePath || "").replace(/\/+$/, "");
      const urls = [`${runtimeBasePath}/productos.json`, "/productos.json", "productos.json"];
      let productos = [];
      for (const url of urls) {
        try {
          const res = await fetch(url);
          if (res.ok) {
            productos = await res.json();
            break;
          }
        } catch (e) { }
      }

      if (productos.length === 0) throw new Error("No se pudo obtener productos.json");

      // Parse items from decrypted array
      // Soporta payload JSON ({id, cantidad, selectedColorId, selectedColorName})
      // y formato legacy "id-cantidad".
      const items = decrypted.map((item) => {
        const trimmed = String(item || "").trim();
        if (!trimmed) return null;
        if (trimmed.startsWith("{")) {
          try {
            const parsed = JSON.parse(trimmed);
            const idVal = String(parsed?.id ?? "").trim();
            const cantVal = Number(parsed?.cantidad);
            if (!idVal || Number.isNaN(cantVal)) return null;
            const cId = Number(parsed?.selectedColorId);
            return {
              id: idVal,
              cantidad: cantVal,
              selectedColorId: Number.isFinite(cId) ? cId : null,
              selectedColorName: parsed?.selectedColorName ? String(parsed.selectedColorName) : null,
            };
          } catch { return null; }
        }
        const lastDash = trimmed.lastIndexOf("-");
        if (lastDash === -1) return null;
        const id = trimmed.slice(0, lastDash).trim();
        const cant = Number(trimmed.slice(lastDash + 1).trim());
        if (!id || Number.isNaN(cant)) return null;
        return { id, cantidad: cant, selectedColorId: null, selectedColorName: null };
      }).filter(Boolean);

      if (items.length === 0) throw new Error("El pedido no tiene productos");

      // Build pedido list - busca por baseId (sin variante)
      const foundItems = items.map((item) => {
        const parsed = parseTokenId(item.id);
        const prod = productos.find((p) => p.id === parsed.baseId);
        if (!prod) return null;
        const colorId = item.selectedColorId !== null ? item.selectedColorId : parsed.colorId;
        let colorName = item.selectedColorName;
        let colorHex = null;
        if (Array.isArray(prod.colors) && colorId !== null && colorId !== undefined) {
          const c = prod.colors.find((c) => c.id === colorId);
          if (c) {
            if (!colorName) colorName = c.name;
            colorHex = c.hex || null;
          }
        }
        return {
          ...prod,
          cantidad: item.cantidad,
          requestedId: item.id,
          baseId: parsed.baseId,
          variantBadgeText: variantBadgeText(parsed.variantToken),
          selectedColorId: colorId,
          selectedColorName: colorName,
          selectedColorHex: colorHex,
          currentUnitPrice: parsePrice(prod.price),
        };
      });
      const missingCount = foundItems.filter((p) => p === null).length;
      const pedidos = foundItems.filter(Boolean);

      const container = document.getElementById("result__container");
      if (!container) return;

      if (pedidos.length === 0) {
        container.innerHTML = '<p class="pedido-message">No se encontraron los productos del pedido en el catálogo.</p>';
        return;
      }

      const total = pedidos.reduce((s, p) => s + p.currentUnitPrice * p.cantidad, 0);
      const warningHtml = missingCount > 0
        ? `<p style="color:#b42318;font-size:0.85rem;font-weight:600;margin:0 0 12px;padding:10px 16px;background:#fff2f0;border-radius:8px;">${missingCount} producto${missingCount > 1 ? "s" : ""} del pedido no se encontraron en el catálogo actual.</p>`
        : "";
      const itemsHtml = pedidos.map((p, i) => {
        const img = Array.isArray(p.img) ? p.img[0] : p.img;
        const badgeClass = p.variantBadgeText && p.variantBadgeText.startsWith("Talle ") ? "pedido-size-badge" : "pedido-variant-badge";
        const variantBadge = p.variantBadgeText ? `<span class="${badgeClass}">${escapeHtml(p.variantBadgeText)}</span>` : "";
        const hasColor = p.selectedColorName || p.selectedColorHex;
        const colorBadge = hasColor
          ? `<span class="pedido-color-badge"><span class="pedido-color-swatch" style="background:${escapeHtml(p.selectedColorHex || '#cccccc')}"></span>${escapeHtml(p.selectedColorName || ("ID " + p.selectedColorId))}</span>`
          : "";
        return `<div class="pedido-item" data-row-key="${i}" data-cantidad="${p.cantidad}" data-unit-price="${p.currentUnitPrice}"><img src="${img}" alt="${escapeHtml(p.name)}" loading="lazy" /><div class="pedido-item-info"><span class="pedido-item-name">${escapeHtml(p.name)}</span>${variantBadge}${colorBadge}<span class="pedido-item-price">$<span>${formatPrice(p.currentUnitPrice)}</span> c/u</span><p class="pedido-check-status">Stock verificar manualmente</p></div><div class="pedido-qty-wrap"><span class="pedido-qty">${p.cantidad}</span></div><div class="pedido-subtotal">$<span>${formatPrice(p.currentUnitPrice * p.cantidad)}</span></div></div>`;
      }).join("");

      container.innerHTML = `${warningHtml}<div class="pedido-list"><div class="pedido-list-header"><span></span><span>Producto</span><span style="text-align:center">Cant.</span><span style="text-align:right">Subtotal</span></div>${itemsHtml}</div><div class="pedido-total-box"><div class="pedido-total-inner"><div class="pedido-total-row"><span>${pedidos.length} productos</span><span>${pedidos.reduce((s, p) => s + p.cantidad, 0)} unidades</span></div><div class="pedido-total-row main"><span>Total</span><span>$<span>${formatPrice(total)}</span></span></div></div></div>`;
    } catch (err) {
      const el = document.getElementById("result__container");
      if (el) el.innerHTML = '<p class="pedido-message">Error: ' + escapeHtml(err.message) + '</p>';
    }
  });
</script>
