---
import ListarProductos from "@components/ListarProductos.astro";
import Layout from "@layouts/Layout.astro";
import { cargarProductos } from "@utils/loadCSV";
import { countCategories } from "@utils/countCategories";
import { productMatchesSubcategory } from "@utils/categoryNormalization";
import { config } from "src/config";
import SideBardCategories from "@components/SideBardCategories.astro";
import type { subCategory } from "src/types/categoryList";
import "../../../style.css";

export const prerender = true;

/** Genera los archivos html por cada subcategoría */
export const getStaticPaths = () => {
  const CANT_PRODUCTOS = config.postPerPage;
  const products = cargarProductos();
  const categories = countCategories(products);

  return categories.flatMap((category) => {
    return category.subcategories.flatMap((sub: subCategory) => {
      const productsPerSubCat = products.filter(
        (p) => productMatchesSubcategory(p, category.name, sub.name),
      );

      const totalPages = Math.ceil(productsPerSubCat.length / CANT_PRODUCTOS);

      return Array.from({ length: totalPages }, (_, i) => {
        const start = i * CANT_PRODUCTOS;
        const end = start + CANT_PRODUCTOS;

        return {
          params: { id: category.name, subcat: sub.name, pag: i + 1 },
          props: {
            products: productsPerSubCat.slice(start, end),
            totalPages,
            subCats: category.subcategories,
          },
        };
      });
    });
  });
};

const { id, subcat, pag } = Astro.params;
const { products, totalPages, subCats } = Astro.props;
const baseUrl = `${config.base}/categories/${id}/${subcat}`;
---

<Layout
  categorySelected={id}
  pageTitle={`${config.pageTitle} - ${id} / ${subcat} / page ${pag}`}
>
  <div class="categories__container">
    <SideBardCategories
      categoryFather={id}
      arrayCategorys={subCats}
      products={products}
    />
    <ListarProductos
      products={products}
      totalPages={totalPages}
      actualPage={pag}
      baseURL={baseUrl}
    />
  </div>
</Layout>
