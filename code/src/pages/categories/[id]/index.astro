---
import ListarProductos from "@components/ListarProductos.astro";
import SideBardCategories from "@components/SideBardCategories.astro";
import Layout from "@layouts/Layout.astro";
import { countCategories } from "@utils/countCategories";
import { loadProducts, loadCategoryProducts } from "@utils/loadProducts";
import { config } from "src/config";
import { withBasePath } from "@utils/basePath";
import type { subCategory } from "src/types/categoryList";
import '../style.css';

const CANT_PRODUCTOS = config.postPerPage;
const { id } = Astro.params;

const allProducts = await loadProducts();
const categories = countCategories(allProducts);

const category = categories.find((c) => c.name === id);
const subcategoryMap = new Map<string, subCategory>();
if (category?.subcategories.length) {
  category.subcategories.forEach((subC) => {
    if (!subcategoryMap.has(subC.name))
      subcategoryMap.set(subC.name, { ...subC });
  });
}

const { products, total } = await loadCategoryProducts({
  category: id!,
  page: 1,
  pageSize: CANT_PRODUCTOS,
});

const totalPages = Math.ceil(total / CANT_PRODUCTOS);
const subCat = Array.from(subcategoryMap.values());
const baseUrl = withBasePath(`/categories/${id}`, Astro.url.pathname);
---

<Layout
  categorySelected={id}
  pageTitle={`${config.pageTitle} - ${id}`}
  pageId="categories"
>
  <div class="categories__container">
    <SideBardCategories
      categoryFather={id}
      arrayCategorys={subCat}
      products={products}
    />

    <ListarProductos
      products={products}
      totalPages={totalPages}
      baseURL={baseUrl}
    />
  </div>
</Layout>
