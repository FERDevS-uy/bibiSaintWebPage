---
import Layout from "../layouts/Layout.astro";
import { config } from "../config";
---

<Layout pageTitle={`${config.pageTitle} - Sobre nosotros`}>
  <section class="contact-container">
    <div class="contact-info">
      <h2>Quienes somos</h2>
      <hr />

      <p class="intro-text">
        Bibi´s Tienda & Bienestar! Descubre una tienda online diferente, donde encontrarás
        productos para eI hogar, vestimenta, accesorios y mucho más. Nos
        apasiona brindarte calidad, novedades y soluciones para tu día a día.
      </p>

      <p class="intro-text">
        ¿Buscas bienestar? Ofrecemos servicios holísticos personalizados para tu
        crecimiento personal
      </p>

      <div class="services-list">
        <strong> Comercializamos los siguientes servicios: </strong>
        <ul>
          <li>De Codificación Biológica por 80 dólares.</li>
          <li>Carta Numerológica por 80 dólares.</li>
          <li>Tutorías individuales ONLINE para estudiantes de EUTM | Medicina y Agronomia por 50 dólares la hora.</li>
        </ul>
      </div>

      <p class="cta-text">
        Te invitamos a completar el formulario de contacto si tenes alguna duda,
        consulta o buscas algún Producto o Servicio particular, a la brevedad
        nos pondremos en contacto.
      </p>
    </div>

    <div class="contact-form-wrapper">
      <form
        class="contact-form"
        action="https://formspree.io/f/mwvzalvq"
        method="POST"
      >
        <input type="hidden" name="_subject" value="Nuevo mensaje desde el formulario de contacto" />
        <input type="hidden" name="_language" value="es" />
        <input type="text" name="name" placeholder="Nombre Completo" required />
        <input type="email" name="email" placeholder="Correo electrónico" required />
        <input type="tel" name="phone" placeholder="Número de Teléfono" required />
        <input type="text" name="subject" placeholder="Asunto" required />
        <textarea name="message" placeholder="Tu Mensaje" rows="8" required></textarea>
        <button type="submit">Enviar</button>
      </form>
    </div>
  </section>
</Layout>

<style>
  .contact-container {
    width: 100%;
    max-width: 940px;
    overflow-x: hidden;
    margin: 2.2rem auto;
    padding: 0 16px;
    display: flex;
    gap: 2.4rem;
    font-family: "Poppins", sans-serif;
    color: #232946;
  }

  /* Left Column */
  .contact-info {
    flex: 1;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  hr {
    border: 0;
    border-top: 1px solid #e0e0e0;
    margin-bottom: 2rem;
  }

  hr.separator {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .intro-text {
    line-height: 1.6;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .services-list {
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .services-list strong {
    display: block;
    margin-bottom: 0.2rem;
  }

  .services-list ul {
    padding-left: 20px;
  }

  .cta-text {
    font-size: 0.95rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .icon-wrapper {
    min-width: 40px; /* Fixed width for icon container to align text */
    text-align: center;
    display: flex;
    justify-content: center;
    padding-top: 2px;
  }

  .icon-wrapper svg {
    color: #999; /* Example gray color */
    width: 32px;
    height: 32px;
    stroke-width: 1.5;
  }
  .icon-wrapper.mobile svg {
    /* Adjust specific icon styles if needed */
    height: 48px; /* Phone icon in design looks simpler/outline */
    width: 40px;
    opacity: 0.4;
  }
  .icon-wrapper.pin svg {
    /* Adjust specific icon styles if needed */
    height: 48px;
    width: 40px;
    opacity: 0.4;
  }

  .detail-text {
    display: flex;
    flex-direction: column;
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-icon {
    /* Base styles handled by global styles or reset here if needed */
    color: #3b5998; /* Default for facebook-ish */
  }
  .social-icon.facebook {
    color: #3b5998;
  }
  .social-icon.instagram {
    color: #8a3ab9; /* approx gradient fallback */
  }
  .social-icon.whatsapp {
    color: #25d366;
  }

  /* Right Column - Form */
  .contact-form-wrapper {
    flex: 1;
    padding-top: 3rem; /* Align with text start approximately */
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  input,
  textarea {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #777;
    border-radius: 25px; /* Pill shape */
    font-size: 1rem;
    color: #555;
    background: transparent;
    outline: none;
    font-family: inherit;
  }

  textarea {
    border-radius: 20px; /* Less rounded for textarea usually, but image shows rounded corners */
    resize: vertical;
  }

  input::placeholder,
  textarea::placeholder {
    color: #888;
  }

  button {
    background-color: #e86c1a; /* Orange from design approx */
    width: 100%;
    color: white;
    border: none;
    padding: 10px 30px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1.1rem;
    cursor: pointer;
    align-self: flex-start;
    transition: background 0.3s;
  }

  button:hover {
    background-color: #d65a0f;
  }

  .form-feedback {
    color: #164f2c;
    font-size: 0.95rem;
    min-height: 1.3rem;
    margin-top: -0.5rem;
  }

  @media (max-width: 768px) {
    .contact-container {
      flex-direction: column;
      gap: 2rem;
    }

    .contact-form-wrapper {
      padding-top: 0;
    }
  }

  @media screen and (min-width: 1000px) {
    button {
      width: auto;
      border-radius: 25px;
    }
  }
</style>
