---
import GlobalStyles from "./GlobalStyles.astro";
import { config } from "src/config";
import { detectBasePath, withBasePath } from "@utils/basePath";
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import { countCategories } from "@utils/countCategories";
import { loadProducts } from "@utils/loadProducts";
import InstruccionesBar from "@components/InstruccionesBar.astro";
import TopBar from "@components/TopBar.astro";
import { ViewTransitions } from "astro:transitions";

const productos = await loadProducts();
const categories = countCategories(productos);
const isDev = import.meta.env.tienda_DEV === "true";
const url_href = Astro.url.href.endsWith("/")
  ? Astro.url.href.slice(0, -1)
  : Astro.url.href;
const basePath = detectBasePath(Astro.url.pathname);

interface Props {
  categorySelected?: string;
  pageTitle?: string;
  description?: string;
  pageImage?: string;
  pageId?: string;
}

const {
  categorySelected,
  pageTitle = config.pageTitle,
  description = config.description,
  pageImage = `${url_href}/icono.webp`,
  pageId,
} = Astro.props;
---

<!doctype html>
<html lang="es" data-base-path={basePath}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/webp"
      href={withBasePath("/icono.webp", Astro.url.pathname)}
    />
    <link
      rel="icon"
      type="image/png"
      href={withBasePath("/icono.png", Astro.url.pathname)}
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>

    <meta itemprop="name" content={pageTitle} />
    <meta itemprop="description" content={description} />
    <meta itemprop="image" content={pageImage} />

    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={pageTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={pageImage} />
    <meta property="og:url" content={url_href} />

    <ViewTransitions />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body id="body" class={isDev ? "dev" : ""}>
    <TopBar />
    <Header categories={categories} categorySelected={categorySelected} basePath={basePath} />

    <main id={pageId}>
      <InstruccionesBar />
      <slot />
    </main>

    <Footer categories={categories} basePath={basePath} />
  </body>

  <GlobalStyles />
</html>

<style>
  main {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  body {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    min-width: 350px;
    color: var(--principal-text-color);
  }
  body.dev::before {
    content: "TEMPLATE";
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-45deg);
    font-size: 5rem;
    color: rgba(255, 0, 0, 0.2); /* rojo con transparencia */
    font-weight: bold;
    pointer-events: none;
    white-space: nowrap;
    z-index: 1000;
  }
  /* Quita el scroll del body cuando se abre el menu */
  body:not(:has(header > .itemsBox.hidden)) {
    overflow: hidden;
  }
</style>
