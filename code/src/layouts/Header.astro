---
import { Astronav, MenuIcon, MenuItems } from "astro-navbar";
import { config } from "src/config";
import type CategoryList from "src/types/categoryList";
import { Image } from "astro:assets";
import SearchInput from "@components/SearchInput.astro";

import logo from "@assets/logo_blanco.png";
const { default: cartSVG } = await import("@assets/cart.svg?raw");
const { default: downSVG } = await import("@assets/down.svg?raw");
const { default: searchSVG } = await import("@assets/search.svg?raw").catch(() => ({ default: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>' }));

interface Props {
  categories: CategoryList[];
  categorySelected?: string;
}
const { categories, categorySelected } = Astro.props;

// Detect current path for mobile active highlight
const pathname = Astro.url.pathname;
const base = config.base || "";
const isHome = pathname === base + "/" || pathname === base || pathname === base + "/index";
const isAbout = pathname.includes("/about");
---

<header>
  <Astronav>
    <div class="headerContainer">
      <MenuIcon class="menuIcon" />
      <div class="logoContainer">
        <a href={config.base}>
          <Image src={logo} alt="logo blanco" />
        </a>
      </div>

      <div class="navMenu">
        <SearchInput />

        <!-- Search toggle button: mobile only -->
        <button id="mobileSearchBtn" class="mobileSearchBtn" title="Buscar" aria-label="Abrir búsqueda">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>

        <a href={`${config.base}/carrito`} class="cartLink">
          <Fragment set:html={cartSVG} />
          <div id="cartCount" class="cartCount hidden">
            <span></span>
          </div>
        </a>
      </div>
    </div>
  </Astronav>

  <MenuItems class="itemsBox hidden">
    <!-- Botón de Cerrar (Mobile) -->
    <div class="mobileMenuHeader">
      <div class="search__container sideBar">
        <SearchInput />
      </div>
      <button id="closeMenuBtn" class="closeMenuBtn">
        <span>&times;</span>
      </button>
    </div>

    <ul class="mainNav">
      <li><a class={`navLink ${isHome ? "active-page" : ""}`} href={config.base}>Inicio</a></li>
    </ul>

    <input
      type="checkbox"
      id="toggleCategories"
      class="toggleCategories"
      hidden
    />

    <label for="toggleCategories" id="toggleCategoriesBtn">
      <Fragment set:html={downSVG} />
    </label>
    <ul class="categoryList">
      {
        categories &&
          categories.map((c) => (
            <li class="categoryItem">
              <a
                href={`${config.base}/categories/${c.name}`}
                class={`navLink categoryLink ${categorySelected === c.name ? "selected" : ""} ${c.subcategories && c.subcategories.length > 0 ? "has-submenu" : ""}`}
                data-submenu-target={`submenu-${c.name.replace(/[^a-zA-Z0-9]/g, "-")}`}
              >
                {c.name}
                {c.subcategories && c.subcategories.length > 0 && (
                  <span class="submenu-indicator">›</span>
                )}
              </a>
              {c.subcategories && c.subcategories.length > 0 && (
                <div
                  class="subcategoryList"
                  id={`submenu-${c.name.replace(/[^a-zA-Z0-9]/g, "-")}`}
                >
                  <div class="submenuHeader">
                    <span class="submenuTitle">{c.name}</span>
                    <button
                      class="backMenuBtn"
                      data-submenu-close={`submenu-${c.name.replace(/[^a-zA-Z0-9]/g, "-")}`}
                    >
                      &larr;
                    </button>
                  </div>
                  <ul>
                    <li>
                      <a
                        href={`${config.base}/categories/${c.name}`}
                        class="principal navLink subcategoryLink"
                        style="font-weight: bold;"
                      >
                        Ver todos
                      </a>
                    </li>
                    {c.subcategories.map((sub) => (
                      <li>
                        <a
                          href={`${config.base}/categories/${c.name}/${sub.name}`}
                          class="navLink subcategoryLink"
                        >
                          {sub.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </li>
          ))
      }
    </ul>

    <ul class="mainNav mainNavBottom">
      <li>
        <a class={`navLink ${isAbout ? "active-page" : ""}`} href={`${config.base}/about`}>Quienes Somos</a>
      </li>
    </ul>
  </MenuItems>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const hasSubmenuLinks = document.querySelectorAll(".has-submenu");
    const backBtns = document.querySelectorAll(".backMenuBtn");
    const closeMenuBtn = document.getElementById(
      "closeMenuBtn",
    ) as HTMLButtonElement;
    const astroNavMenu = document.getElementById(
      "astronav-menu",
    ) as HTMLButtonElement;
    const mobileSearchBtn = document.getElementById("mobileSearchBtn");
    const searchForm = document.querySelector(".navMenu form");

    // Abrir submenús
    hasSubmenuLinks.forEach((link) => {
      if (window.innerWidth <= 600) {
        link.addEventListener("click", (e) => {
          e.stopPropagation();
          e.preventDefault();
          const targetId = link.getAttribute("data-submenu-target");
          if (targetId) {
            const submenu = document.getElementById(targetId);
            if (submenu) {
              submenu.classList.add("open");
            }
          }
        });
      }
    });

    // Retroceder al menú principal
    backBtns.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        const targetId = btn.getAttribute("data-submenu-close");
        if (targetId) {
          const submenu = document.getElementById(targetId);
          if (submenu) {
            submenu.classList.remove("open");
          }
        }
      });
    });

    // Cerrar el panel móvil entero
    closeMenuBtn.addEventListener("click", () => {
      astroNavMenu.click();
    });

    // Mobile search toggle: opens mobile drawer and focuses the search input inside it
    if (mobileSearchBtn) {
      mobileSearchBtn.addEventListener("click", () => {
        // Only click the burger if the menu is hidden
        if (astroNavMenu.getAttribute("aria-expanded") !== "true") {
          astroNavMenu.click();
        }
        // Focus the search input inside the sidebar menu
        setTimeout(() => {
          const sidebarInput = document.querySelector(".search__container.sideBar input") as HTMLInputElement;
          if (sidebarInput) {
            sidebarInput.focus();
            // Also move the cursor to the end if there's text
            const val = sidebarInput.value;
            sidebarInput.value = "";
            sidebarInput.value = val;
          }
        }, 300); // Wait for CSS transition of menu opening
      });
    }
  });
</script>

<script type="module">
  // Mostrar cantidad de productos en el carrito
  window.updateCartCount = function () {
    const cartCount = document.getElementById("cartCount");
    const cartCountSpan = document.querySelector("#cartCount span");

    const carrito = JSON.parse(localStorage.getItem("carrito") || "[]");
    const count = carrito.reduce((acc, p) => acc + (p.cantidad || 1), 0);

    if (cartCount) {
      if (count > 0) {
        cartCountSpan.textContent = count;
        cartCount.classList.remove("hidden");
      } else {
        cartCount.classList.add("hidden");
      }
    }
  };

  // Llama una vez al cargar
  window.updateCartCount();

  // Opcional: actualiza en tiempo real si el carrito cambia en otra pestaña
  window.addEventListener("storage", (e) => {
    if (e.key === "carrito") window.updateCartCount();
  });

  function checkCategoryListWidth() {
    const categoryList = document.querySelector(".categoryList");
    const toggleBtn = document.getElementById("toggleCategoriesBtn");

    if (!categoryList || !toggleBtn) return;

    // Solo en escritorio
    if (window.innerWidth >= 1000) {
      // Mostrar el botón solo si el ancho visible es exactamente 1000px
      if (categoryList.offsetWidth >= 757) {
        toggleBtn.style.display = "flex";
      } else {
        toggleBtn.style.display = "none";
      }
    } else {
      toggleBtn.style.display = "none";
    }
  }

  // Ejecutar al cargar y al redimensionar
  window.addEventListener("DOMContentLoaded", checkCategoryListWidth);
  window.addEventListener("resize", checkCategoryListWidth);
</script>

<style>
  header {
    margin-bottom: 0.5rem;
    background: #c11010;
    background: linear-gradient(
      0deg,
      var(--p-b-color) 0%,
      var(--s-b-color) 100%
    );
  }

  /* Yellow bottom border & hiding elements on mobile */
  @media screen and (max-width: 999px) {
    header {
      border-bottom: 3px solid var(--line-color);
    }
    .navMenu .searchForm {
      display: none !important;
    }
  }

  .headerContainer {
    color: var(--secondary-text-color);
    margin: auto;
    width: 100%;
    max-width: 1000px;
    height: var(--header-height);

    display: flex;
    flex-direction: row;
    align-items: center;
    padding-inline: 1rem;
  }

  .logoContainer {
    flex: 1;
    height: 75px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* --- SEARCH FORM --- */
  .search__container {
    display: none;
    padding-inline: 5rem;
    padding-block: 1.5rem;
    flex: 1;
  }
  .search__container.sideBar {
    display: inherit;
    padding: 0;
  }
  .navMenu {
    flex: 0 0 auto;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
  }
  .navMenu form {
    flex: 1;
    padding-inline: 1rem;
    padding-block: 1.5rem;
    display: none; /* Oculto en mobile */
  }
  .navMenu form input {
    width: 100%;
    border-radius: 5px;
    padding: 5px 10px;
    border: 1px solid var(--line-color);
  }

  /* Mobile search button */
  .mobileSearchBtn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.2);
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    cursor: pointer;
    flex-shrink: 0;
    color: #fff;
  }
  .mobileSearchBtn svg {
    width: 20px;
    height: 20px;
  }
  .mobileSearchBtn:hover {
    background: rgba(255,255,255,0.35);
  }

  /* --- CART --- */
  .cartLink {
    color: var(--secondary-text-color);
    text-decoration: none;
    display: flex;
    align-items: center;
    position: relative; /* Necesario para contener el SVG absoluto en mobile */
    width: 50px;
    height: 75px;
    flex-shrink: 0;
  }
  .cartLink:hover {
    animation: shake 0.5s infinite;
  }
  .cartCount span {
    background-color: var(--line-color);
    border-radius: 50%;
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    justify-content: center;
    position: absolute;
    right: 5px;
    top: 15px;
    z-index: 10;
  }

  /* --- ITEMS BOX (Mobile Drawer) --- */
  .itemsBox {
    position: fixed;
    top: 0;
    left: 0;
    width: 85vw;
    max-width: 400px;
    min-width: 310px;
    height: 100vh;
    background: var(
      --h-gradient
    ); /* linear-gradient(135deg, #e43f3f 0%, #b81c1c 100%) */
    z-index: 1000;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    overflow-y: auto;
    box-shadow: 2px 0 10px rgba(0, 0, 0, 0.5);
    transition: transform 0.3s ease;
  }
  .itemsBox.hidden {
    transform: translateX(-100%);
    display: none;
  }

  .mobileMenuHeader {
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 5rem;
    padding-inline: 1.4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
  }
  .closeMenuBtn {
    background: none;
    border: none;
    color: white;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .closeMenuBtn span {
    display: flex;
    align-items: center;
    height: 30px;
    font-weight: bold;
    font-size: 2rem;
  }

  .itemsBox ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .itemsBox .mainNav li,
  .itemsBox .categoryList > li,
  .subcategoryList ul > li {
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
  }

  .navLink {
    color: white;
    text-decoration: none;
    font-size: 1.3rem;
    font-weight: bold;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .navLink:hover,
  .navLink.focus {
    background-color: rgba(255, 255, 255, 0.1);
  }
  /* Active page highlight in mobile menu */
  .navLink.active-page,
  .categoryLink.selected {
    color: var(--line-color) !important;
    background-color: rgba(255, 255, 255, 0.08);
  }
  .submenu-indicator {
    font-size: 1.5rem;
    line-height: 1;
  }

  /* Submenu Drilldown */
  .subcategoryList {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    min-height: 100%;
    background: var(--h-gradient);
    z-index: 10;
    transform: translateX(-100%);
    transition: transform 0.3s ease-in-out;
    display: flex;
    flex-direction: column;
  }
  .subcategoryList.open {
    transform: translateX(0);
  }

  .submenuHeader {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #ccc;
    color: black;
  }
  .submenuTitle {
    color: white;
    text-decoration: none;
    font-size: 1.3rem;
    font-weight: bold;
    display: flex;
  }
  .backMenuBtn {
    background: none;
    border: none;
    font-size: 2rem;
    color: #ffffff;
    cursor: pointer;
    display: flex;
    align-items: center;
  }

  /* TAMAÑO PC */
  @media screen and (min-width: 1000px) {
    header {
      /* --header-icon-size: 7rem; */
    }

    .logoContainer {
      flex: 0 0 auto;
    }

    /* --- MENU ICON --- */
    .headerContainer .menuIcon {
      display: none;
    }
    /* Mostrar barra de búsqueda en desktop */
    .navMenu {
      flex: 1;
    }
    .navMenu form {
      display: block;
      position: relative;
    }

    .search__container {
      display: inherit;
    }

    /* --- CART --- */
    .cartLink {
      position: relative;
      width: 50px;
      height: 75px;
    }

    /* --- ITEMS BOX --- */
    .itemsBox,
    .itemsBox.hidden {
      border-top: 2px solid var(--line-color);
      box-shadow: none;
      transition: none;
      transform: none !important;
      background-color: transparent;

      display: flex !important;
      justify-content: center;
      margin: auto;
      flex-direction: row-reverse;

      position: static;
      width: auto;
      height: auto;
      max-width: none;
      overflow: visible;
    }
    .itemsBox > ul {
      display: flex;
    }
    .itemsBox ul.mainNav {
      margin-left: 20px;
    }

    .mobileMenuHeader {
      display: none;
    }

    .itemsBox .mainNav li,
    .itemsBox .categoryList > li {
      border-bottom: none;
      position: relative;
    }

    .navLink {
      color: var(--secondary-text-color);
      overflow-x: hidden;
      text-wrap: nowrap;
      width: 100%;
      display: block;
      text-decoration: none;
      padding: 0.5rem 1rem;
      font-weight: normal;
      font-size: 1rem;
    }
    .navLink.principal {
      display: none;
    }
    .navLink:hover,
    .navLink.focus,
    .categoryLink.selected {
      background-color: rgba(0, 0, 0, 0.08);
    }
    .submenu-indicator {
      font-size: 1rem;
      margin-left: 5px;
    }

    .subcategoryList {
      transition: none;
      transform: none;
      display: none;
      position: absolute;
      background: var(--s-b-color);
      min-width: 180px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      z-index: 5;
      border-radius: 0 0 10px 10px;
      left: 0;
      top: 100%;
    }

    .submenuHeader {
      display: none;
    }

    .subcategoryLink {
      padding: 0.5rem 1rem;
      border-bottom: none;
      color: var(--text-color);
    }

    .categoryItem {
      color: var(--secondary-text-color);
    }
    .categoryItem:hover .subcategoryList {
      display: block;
    }

    @keyframes shake {
      0% {
        transform: translateY(0);
      }
      15% {
        transform: translateY(-5px);
      }
      30% {
        transform: translateY(5px);
      }
      45% {
        transform: translateY(-5px);
      }
      60% {
        transform: translateY(5px);
      }
      75% {
        transform: translateY(-5px);
      }
      100% {
        transform: translateY(0);
      }
    }
  }
</style>

<style is:global>
  header .logoContainer img {
    height: 75px;
    width: auto;
    max-width: 200px;
    display: block;
  }

  /* --- CART --- */
  header .cartLink svg {
    width: calc(var(--menu-size) - 10px);
    height: calc(var(--menu-size) - 10px);
    position: absolute;
    top: 22px;
  }

  /* --- MENU ICON --- */
  #astronav-menu {
    border: none;
    cursor: pointer;
    background-image: none;
    background-color: transparent;
    color: inherit;

    display: flex;
    align-items: center;
    justify-content: center;
  }
  #astronav-menu svg {
    width: calc(var(--menu-size) - 10px);
    height: calc(var(--menu-size) - 10px);
  }
  /* Yellow burger lines on mobile */
  @media screen and (max-width: 999px) {
    #astronav-menu svg line,
    #astronav-menu svg rect,
    #astronav-menu svg path {
      stroke: var(--line-color);
      fill: var(--line-color);
    }
    /* Hide mobile search button on desktop */
  }
  @media screen and (min-width: 1000px) {
    header .mobileSearchBtn {
      display: none;
    }
  }
</style>
