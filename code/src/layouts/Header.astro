---
import { Astronav, MenuIcon, MenuItems } from "astro-navbar";
import { config } from "src/config";
import type CategoryList from "src/types/categoryList";
import { Image } from "astro:assets";

import logo from "@assets/logo_blanco.png";
const { default: cartSVG } = await import("@assets/cart.svg?raw");
const { default: downSVG } = await import("@assets/down.svg?raw");

interface Props {
  categories: CategoryList[];
  categorySelected?: string;
}
const { categories, categorySelected } = Astro.props;
---

<header>
  <Astronav>
    <div class="headerContainer">
      <div class="logoContainer">
        <a href={config.base}>
          <Image src={logo} alt="logo blanco" />
        </a>
      </div>

      <div class="navMenu">
        <form class="searchContainer">
          <input
            id="searchInput"
            type="text"
            placeholder="Buscar productos..."
            autocomplete="off"
            class="searchInput"
            name="search"
          />
          <ul id="searchResults" class="searchResults"></ul>
        </form>

        <a href={`${config.base}/carrito`} class="cartLink">
          <Fragment set:html={cartSVG} />
          <div id="cartCount" class="cartCount hidden">
            <span></span>
          </div>
        </a>
        <MenuIcon class="menuIcon" />
      </div>
    </div>
  </Astronav>

  <MenuItems class="itemsBox hidden">
    <!-- Botón de Cerrar (Mobile) -->
    <div class="mobileMenuHeader">
      <button id="closeMenuBtn" class="closeMenuBtn">
        <span style="font-weight: bold; font-size: 1.2rem;">&times;</span> Cerrar
      </button>
    </div>

    <ul class="mainNav">
      <li><a class="navLink" href={config.base}>Inicio</a></li>
    </ul>

    <input
      type="checkbox"
      id="toggleCategories"
      class="toggleCategories"
      hidden
    />

    <label for="toggleCategories" id="toggleCategoriesBtn">
      <Fragment set:html={downSVG} />
    </label>
    <ul class="categoryList">
      {
        categories &&
          categories.map((c) => (
            <li class="categoryItem">
              <a
                href={`${config.base}/categories/${c.name}`}
                class={`navLink categoryLink ${categorySelected === c.name ? "selected" : ""} ${c.subcategories && c.subcategories.length > 0 ? "has-submenu" : ""}`}
                data-submenu-target={`submenu-${c.name.replace(/[^a-zA-Z0-9]/g, "-")}`}
              >
                {c.name}
                {c.subcategories && c.subcategories.length > 0 && (
                  <span class="submenu-indicator">›</span>
                )}
              </a>
              {c.subcategories && c.subcategories.length > 0 && (
                <div
                  class="subcategoryList"
                  id={`submenu-${c.name.replace(/[^a-zA-Z0-9]/g, "-")}`}
                >
                  <div class="submenuHeader">
                    <span class="submenuTitle">{c.name}</span>
                    <button
                      class="backMenuBtn"
                      data-submenu-close={`submenu-${c.name.replace(/[^a-zA-Z0-9]/g, "-")}`}
                    >
                      &larr;
                    </button>
                  </div>
                  <ul>
                    <li>
                      <a
                        href={`${config.base}/categories/${c.name}`}
                        class="navLink subcategoryLink"
                        style="font-weight: bold;"
                      >
                        Ver todos
                      </a>
                    </li>
                    {c.subcategories.map((sub) => (
                      <li>
                        <a
                          href={`${config.base}/categories/${c.name}/${sub.name}`}
                          class="navLink subcategoryLink"
                        >
                          {sub.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </li>
          ))
      }
    </ul>

    <ul class="mainNav mainNavBottom">
      <li>
        <a class="navLink" href={`${config.base}/about`}>Quienes Somos</a>
      </li>
    </ul>
  </MenuItems>
</header>

<script>
  import DOMPurify from "dompurify";
  import { config } from "src/config";
  const searchContainerForm = document.querySelector(
    "form.searchContainer",
  ) as HTMLFormElement;

  searchContainerForm.addEventListener("submit", (e) => {
    e.preventDefault();

    const formData = new FormData(searchContainerForm).get("search");
    if (!formData) return;
    const searchTerm = DOMPurify.sanitize(formData.toString().toLowerCase());

    if (!searchTerm || searchTerm.length < 3) return;

    const url = new URL(config.base + "/search", window.location.origin);
    url.searchParams.set("q", searchTerm);
    window.location.assign(url.toString());
  });
</script>

<script type="module">
  // Mostrar cantidad de productos en el carrito
  window.updateCartCount = function () {
    const cartCount = document.getElementById("cartCount");
    const cartCountSpan = document.querySelector("#cartCount span");

    const carrito = JSON.parse(localStorage.getItem("carrito") || "[]");
    const count = carrito.reduce((acc, p) => acc + (p.cantidad || 1), 0);

    if (cartCount) {
      if (count > 0) {
        cartCountSpan.textContent = count;
        cartCount.classList.remove("hidden");
      } else {
        cartCount.classList.add("hidden");
      }
    }
  };

  // Llama una vez al cargar
  window.updateCartCount();

  // Opcional: actualiza en tiempo real si el carrito cambia en otra pestaña
  window.addEventListener("storage", (e) => {
    if (e.key === "carrito") window.updateCartCount();
  });

  function checkCategoryListWidth() {
    const categoryList = document.querySelector(".categoryList");
    const toggleBtn = document.getElementById("toggleCategoriesBtn");

    if (!categoryList || !toggleBtn) return;

    // Solo en escritorio
    if (window.innerWidth >= 1000) {
      // Mostrar el botón solo si el ancho visible es exactamente 1000px
      if (categoryList.offsetWidth >= 757) {
        toggleBtn.style.display = "flex";
      } else {
        toggleBtn.style.display = "none";
      }
    } else {
      toggleBtn.style.display = "none";
    }
  }
  // ...existing code...

  let productosCache = null;

  async function fetchProductos() {
    if (productosCache) return productosCache;
    const res = await fetch("/productos.json");
    productosCache = await res.json();
    return productosCache;
  }

  const searchInput = document.getElementById("searchInput");
  const searchResults = document.getElementById("searchResults");

  if (searchInput && searchResults) {
    searchInput.addEventListener("input", async (e) => {
      const query = e.target.value.trim().toLowerCase();
      if (!query) {
        searchResults.style.display = "none";
        searchResults.innerHTML = "";
        return;
      }
      const productos = await fetchProductos();
      const resultados = productos
        .filter((p) => p.name.toLowerCase().includes(query))
        .slice(0, 10); // máximo 10 resultados

      if (resultados.length === 0) {
        searchResults.innerHTML = "<li>No se encontraron productos</li>";
      } else {
        searchResults.innerHTML = resultados
          .map(
            (p) =>
              `<li class="searchResultItem" onclick="window.location.href='/template-static-ecommerce/producto/${p.id}'">
    <span class="searchResultName">${p.name}</span>
    <span class="searchResultPrice">$${p.price || p.precio || ""}</span>
  </li>`,
          )
          .join("");
      }
      searchResults.style.display = "block";
    });

    // Ocultar resultados al perder foco
    searchInput.addEventListener("blur", () => {
      setTimeout(() => {
        searchResults.style.display = "none";
      }, 200);
    });
    searchInput.addEventListener("focus", () => {
      if (searchResults.innerHTML) searchResults.style.display = "block";
    });
    searchInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        const query = searchInput.value.trim();

        if (query) {
          window.location.href = `/bibiSaintWebPage/search/page/1?q=${encodeURIComponent(query)}`;
        }
      }
    });
  }
  // --- Lógica del menú móvil ---
  document.addEventListener("DOMContentLoaded", () => {
    const isMobile = () => window.innerWidth < 1000;
    // Abrir submenús
    const hasSubmenuLinks = document.querySelectorAll(".has-submenu");
    hasSubmenuLinks.forEach((link) => {
      link.addEventListener("click", (e) => {
        if (isMobile()) {
          // Prevenir que el click se propague al componente Astronav y lo cierre
          e.stopPropagation();
          e.preventDefault();
          const targetId = link.getAttribute("data-submenu-target");
          if (targetId) {
            const submenu = document.getElementById(targetId);
            if (submenu) {
              submenu.classList.add("open");
            }
          }
        }
      });
    });

    // Retroceder al menú principal
    const backBtns = document.querySelectorAll(".backMenuBtn");
    backBtns.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        const targetId = btn.getAttribute("data-submenu-close");
        if (targetId) {
          const submenu = document.getElementById(targetId);
          if (submenu) {
            submenu.classList.remove("open");
          }
        }
      });
    });

    // Cerrar el panel móvil entero
    const closeMenuBtn = document.getElementById("closeMenuBtn");
    if (closeMenuBtn) {
      closeMenuBtn.addEventListener("click", () => {
        const itemsBox = document.querySelector(".itemsBox");
        if (itemsBox) {
          itemsBox.classList.add("hidden");
          // Limpiar submenús abiertos
          document.querySelectorAll(".subcategoryList.open").forEach((sub) => {
            sub.classList.remove("open");
          });
        }
      });
    }
  });

  // Ejecutar al cargar y al redimensionar
  window.addEventListener("DOMContentLoaded", checkCategoryListWidth);
  window.addEventListener("resize", checkCategoryListWidth);
</script>

<style>
  header {
    margin-bottom: 0.5rem;
    background: #c11010;
    background: linear-gradient(
      0deg,
      var(--p-b-color) 0%,
      var(--s-b-color) 100%
    );
  }

  .headerContainer {
    color: var(--text-color);
    margin: auto;
    max-width: 1400px;
    width: 100%;
    height: 75px;

    display: flex;
    flex-direction: row;
    align-items: center;
    padding-inline: 1rem;
  }

  .logoContainer {
    flex: 0 0 auto;
    height: 75px;
    display: flex;
    align-items: center;
  }

  /* --- SEARCH FORM --- */
  .navMenu {
    flex: 1;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
  }
  .navMenu form {
    flex: 1;
    padding-inline: 1rem;
    padding-block: 1.5rem;
    display: none; /* Oculto en mobile */
  }
  .navMenu form input {
    width: 100%;
    border-radius: 5px;
    padding: 5px 10px;
    border: 1px solid var(--line-color);
  }

  /* --- CART --- */
  .cartLink {
    color: var(--text-color);
    text-decoration: none;
    display: flex;
    align-items: center;
    position: relative; /* Necesario para contener el SVG absoluto en mobile */
    width: 50px;
    height: 75px;
    flex-shrink: 0;
  }
  .cartLink:hover {
    animation: shake 0.5s infinite;
  }
  .cartCount span {
    background-color: var(--line-color);
    border-radius: 50%;
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    justify-content: center;
    position: absolute;
    right: 5px;
    top: 15px;
    z-index: 10;
  }

  /* --- ITEMS BOX (Mobile Drawer) --- */
  .itemsBox {
    position: fixed;
    top: 0;
    left: 0;
    width: 85vw;
    max-width: 400px;
    height: 100vh;
    background: #e63946;
    background: linear-gradient(135deg, #e43f3f 0%, #b81c1c 100%);
    z-index: 1000;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    overflow-y: auto;
    box-shadow: 2px 0 10px rgba(0, 0, 0, 0.5);
    transition: transform 0.3s ease;
  }
  .itemsBox.hidden {
    transform: translateX(-100%);
    display: none;
  }

  .mobileMenuHeader {
    display: flex;
    justify-content: flex-end;
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
  }
  .closeMenuBtn {
    background: none;
    border: none;
    color: white;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .itemsBox ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .itemsBox .mainNav li,
  .itemsBox .categoryList > li {
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
  }

  .navLink {
    color: white;
    text-decoration: none;
    font-size: 1.3rem;
    font-weight: bold;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .navLink:hover,
  .navLink.focus,
  .categoryLink.selected {
    background-color: rgba(255, 255, 255, 0.1);
  }
  .submenu-indicator {
    font-size: 1.5rem;
    line-height: 1;
  }

  /* Submenu Drilldown */
  .subcategoryList {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    min-height: 100%;
    background-color: #c11010;
    z-index: 10;
    transform: translateX(-100%);
    transition: transform 0.3s ease-in-out;
    display: flex;
    flex-direction: column;
  }
  .subcategoryList.open {
    transform: translateX(0);
  }

  .submenuHeader {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    background-color: #ffffff;
    border-bottom: 1px solid #ccc;
    color: black;
  }
  .submenuTitle {
    font-size: 1.3rem;
    font-weight: bold;
    color: #333;
  }
  .backMenuBtn {
    background: none;
    border: none;
    font-size: 1.8rem;
    color: #555;
    cursor: pointer;
    display: flex;
    align-items: center;
  }

  .subcategoryLink {
    color: #333;
    font-weight: normal;
    font-size: 1.1rem;
    border-bottom: 1px solid #eee;
  }
  .subcategoryLink:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }

  /* TAMAÑO PC */
  @media screen and (min-width: 1000px) {
    header {
      --header-icon-size: 7rem;
    }
    /* --- MENU ICON --- */
    .navMenu .menuIcon {
      display: none;
    }
    /* Mostrar barra de búsqueda en desktop */
    .navMenu form {
      display: block;
      position: relative;
    }

    /* --- CART --- */
    .cartLink {
      position: relative;
      width: 50px;
      height: 75px;
    }

    /* --- ITEMS BOX --- */
    .itemsBox,
    .itemsBox.hidden {
      border-top: 2px solid var(--line-color);
      box-shadow: none;
      transition: none;
      transform: none !important;
      background-color: transparent;

      display: flex !important;
      justify-content: center;
      margin: auto;
      flex-direction: row-reverse;

      position: static;
      width: auto;
      height: auto;
      max-width: none;
      overflow: visible;
    }
    .itemsBox > ul {
      display: flex;
    }
    .itemsBox ul.mainNav {
      margin-left: 20px;
    }

    .mobileMenuHeader {
      display: none;
    }

    .itemsBox .mainNav li,
    .itemsBox .categoryList > li {
      border-bottom: none;
      position: relative;
    }

    .navLink {
      color: var(--text-color);
      overflow-x: hidden;
      text-wrap: nowrap;
      width: 100%;
      display: block;
      text-decoration: none;
      padding: 0.5rem 1rem;
      font-weight: normal;
      font-size: 1rem;
    }
    .navLink:hover,
    .navLink.focus,
    .categoryLink.selected {
      background-color: rgba(0, 0, 0, 0.08);
    }
    .submenu-indicator {
      font-size: 1rem;
      margin-left: 5px;
    }

    .subcategoryList {
      transition: none;
      transform: none;
      display: none;
      position: absolute;
      background: var(--background-color);
      min-width: 180px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      z-index: 10;
      border-radius: 0 0 10px 10px;
      left: 0;
      top: 100%;
    }

    .submenuHeader {
      display: none;
    }

    .subcategoryLink {
      padding: 0.5rem 1rem;
      border-bottom: none;
      color: var(--text-color);
    }

    .categoryItem:hover .subcategoryList {
      display: block;
    }

    @keyframes shake {
      0% {
        transform: translateY(0);
      }
      15% {
        transform: translateY(-5px);
      }
      30% {
        transform: translateY(5px);
      }
      45% {
        transform: translateY(-5px);
      }
      60% {
        transform: translateY(5px);
      }
      75% {
        transform: translateY(-5px);
      }
      100% {
        transform: translateY(0);
      }
    }
  }
</style>

<style is:global>
  header .logoContainer img {
    height: 75px;
    width: auto;
    max-width: 200px;
    display: block;
  }

  /* --- CART --- */
  header .cartLink svg {
    width: calc(var(--menu-size) - 10px);
    height: calc(var(--menu-size) - 10px);
    position: absolute;
    top: 22px;
  }

  /* --- MENU ICON --- */
  #astronav-menu {
    background-color: transparent;
    border: none;
    cursor: pointer;
    background-image: none;
    color: inherit;

    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
