---
import type CategoryList from "src/types/categoryList";
import { Image } from "astro:assets";

import logo from "@assets/logo_blanco.png";
const { default: logoSVG } = await import("@assets/logoFD.svg?raw");
const { default: facebookSVG } = await import("@assets/facebook.svg?raw");
const { default: instagramSVG } = await import("@assets/instagram.svg?raw");
const { default: whatsappSVG } = await import("@assets/whatsapp.svg?raw");
const { default: mercadoPagoSVG } = await import("@assets/mercadoPago.svg?raw");
const { default: bankSVG } = await import("@assets/bank.svg?raw");

interface Props {
  categories: CategoryList[];
}
const { categories } = Astro.props;
---

<footer class="footer">
  <div class="footerContainer">
    <div class="col1">
      <a href={import.meta.env.BASE_URL}>
        <Image src={logo} alt="logo blanco" />
      </a>
      <p>Bibi's - Donde cada elección tiene alma</p>
    </div>
    <ul class="col2">
      <h3>CATEGORÍAS</h3>
      <ul>
        {
          categories &&
            categories.length > 0 &&
            categories
              .map((cat) => (
                <li>
                  <a
                    href={`${import.meta.env.BASE_URL}/categories/${cat.name}`}
                  >
                    {cat.name}
                  </a>
                </li>
              ))
              .slice(0, 5)
        }
      </ul>
    </ul>
    <ul class="col3">
      <h3>MEDIOS DE PAGOS</h3>
      <ul>
        <li title="Transferencia"><Fragment set:html={bankSVG} /></li>
        <li title="Mercado Pago"><Fragment set:html={mercadoPagoSVG} /></li>
      </ul>
    </ul>
    <ul class="col4">
      <h3>CONTACTO</h3>
      <li>
        <a class="navLink" href={`${import.meta.env.BASE_URL}/about`}
          >Quienes somos</a
        >
      </li>
      <li title="Instagram">
        <a
          href="https://instagram.com/bibisventasonline"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Fragment set:html={instagramSVG} />
        </a>
      </li>
      <li title="Facebook">
        <a
          href="https://facebook.com/bibicartanumerologica"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Fragment set:html={facebookSVG} />
        </a>
      </li>
      <li title="Whatsapp">
        <a
          href="https://wa.me/+59891361706"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Fragment set:html={whatsappSVG} />
        </a>
      </li>
    </ul>
  </div>
</footer>

<style>
  .footer {
    background: #c11010;
    background: linear-gradient(
      0deg,
      var(--p-b-color) 0%,
      var(--s-b-color) 100%
    );
    padding: 3rem 10px;
    font-size: 0.9rem;
    color: var(--text-color);
  }

  .footer h3 {
    text-wrap: nowrap;
    margin-bottom: 0.5rem;
  }

  .footer ul {
    list-style: none;
    padding: 0;
  }

  .footerContainer {
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 3rem 5rem;
    flex-wrap: wrap;
  }

  .footerContainer > * {
    width: 200px;
    min-width: 100px;
    padding-inline: 10px;
  }

  .footerContainer a {
    color: #fff;
    text-decoration: none;
    text-wrap: nowrap;
  }

  .col1 img {
    width: 100%;
    height: auto;
  }
  .col1 p {
    text-wrap: auto;
  }

  .col2 li {
    margin-bottom: 0.5rem;
  }

  a:hover {
    opacity: 0.7;
  }

  .col3 ul {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
  }

  .col4 {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: flex-start;
    align-content: flex-start;
  }
  .col4 li:first-of-type {
    width: 100%;
    /* text-align: start; */
  }

  :global(.col3 svg),
  :global(.col4 svg) {
    width: 30px;
    height: 30px;
  }

  @media (max-width: 600px) {
  }
</style>
