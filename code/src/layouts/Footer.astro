---
import type CategoryList from "src/types/categoryList";
import { Image } from "astro:assets";

import logo from "@assets/logo_blanco.png";
import { Icon } from "astro-icon/components";
const { default: facebookSVG } = await import("@assets/facebook.svg?raw");
const { default: instagramSVG } = await import("@assets/instagram.svg?raw");
const { default: whatsappSVG } = await import("@assets/whatsapp.svg?raw");
const { default: mercadoPagoSVG } = await import("@assets/mercadoPago.svg?raw");
const { default: bankSVG } = await import("@assets/bank.svg?raw");
const globeSVG = '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>';

interface Props {
  categories: CategoryList[];
}
const { categories } = Astro.props;
---

<footer>
  <div class="footerContainer mobile">
    <div class="contact-details">
      <h2 class="title">Contacto</h2>

      <div class="detail-item">
        <div class="icon-wrapper mobile">
          <Icon name="phone" width="24" height="24" />
        </div>
        <div class="detail-text">
          <p>Telefono: +598 91 361 706</p>
          <p>Mail: bibisventasyserviciosonline@gmail.com</p>
        </div>
      </div>

      <div class="detail-item">
        <div class="icon-wrapper pin">
          <Icon name="location" width="24" height="24" />
        </div>
        <div class="detail-text">
          <span
            >Dirección: Dr. Baltasar Brum 1154, 60000 Paysandú, Departamento de
            Paysandú, Uruguay</span
          >
        </div>
      </div>
    </div>

    <hr class="separator" />

    <div class="social_medias">
      <Image src={logo} alt="logo blanco" class="logo" />

      <ul class="social-icons-list">
        <li>
          <a
            href="https://facebook.com/bibicartanumerologica"
            target="_blank"
            rel="noopener noreferrer"
            title="Facebook"
          >
            <Fragment set:html={facebookSVG} />
          </a>
        </li>
        <li>
          <a
            href="https://instagram.com/bibisventasonline"
            target="_blank"
            rel="noopener noreferrer"
            title="Instagram"
          >
            <Fragment set:html={instagramSVG} />
          </a>
        </li>
        <li>
          <a
            href="https://wa.me/+59891361706"
            target="_blank"
            rel="noopener noreferrer"
            title="Whatsapp"
          >
            <Fragment set:html={whatsappSVG} />
          </a>
        </li>
        <li>
          <a
            href="#"
            title="Website"
          >
            <Fragment set:html={globeSVG} />
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="footerContainer desktop">
    <div class="col1">
      <a href={import.meta.env.BASE_URL}>
        <Image class="logo" src={logo} alt="logo blanco" />
      </a>
      <p>Bibi's - Donde cada elección tiene alma</p>
    </div>

    <ul class="col2">
      <h3>CATEGORÍAS</h3>
      <ul class="cats-list">
        {
          categories &&
            categories.length > 0 &&
            categories
              .map((cat) => (
                <li>
                  <a
                    href={`${import.meta.env.BASE_URL}/categories/${cat.name}`}
                  >
                    {cat.name}
                  </a>
                </li>
              ))
              .slice(0, 5)
        }
      </ul>
    </ul>

    <ul class="col3">
      <h3>MEDIOS DE PAGOS</h3>
      <ul class="payments-list">
        <li title="Transferencia"><Fragment set:html={bankSVG} /></li>
        <li title="Mercado Pago"><Fragment set:html={mercadoPagoSVG} /></li>
      </ul>
    </ul>

    <div class="col4 social_medias">
      <h3>CONTACTO</h3>
      <a class="navLink" href={`${import.meta.env.BASE_URL}/about`}
        >Quienes somos</a
      >
      <ul class="social-icons-list">
        <li>
          <a
            href="https://facebook.com/bibicartanumerologica"
            target="_blank"
            rel="noopener noreferrer"
            title="Facebook"
          >
            <Fragment set:html={facebookSVG} />
          </a>
        </li>
        <li>
          <a
            href="https://instagram.com/bibisventasonline"
            target="_blank"
            rel="noopener noreferrer"
            title="Instagram"
          >
            <Fragment set:html={instagramSVG} />
          </a>
        </li>
        <li>
          <a
            href="https://wa.me/+59891361706"
            target="_blank"
            rel="noopener noreferrer"
            title="Whatsapp"
          >
            <Fragment set:html={whatsappSVG} />
          </a>
        </li>
        <li>
          <a
            href="#"
            title="Website"
          >
            <Fragment set:html={globeSVG} />
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>

<style>
  /* ------------------------- Global ------------------------- */
  .separator {
    margin-block: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.5);
  }

  p {
    word-break: break-word;
  }

  a {
    text-decoration: none;
    text-wrap: nowrap;
    color: var(--secondary-text-color);
  }
  a:hover {
    opacity: 0.7;
  }

  footer {
    background: #c11010;
    background: linear-gradient(
      0deg,
      var(--p-b-color) 0%,
      var(--s-b-color) 100%
    );
    border-radius: 20px 20px 0 0;
    padding: 20px 10px;
    font-size: 0.9rem;
    color: var(--secondary-text-color);
  }

  h3 {
    color: var(--secondary-text-color);
    text-wrap: nowrap;
    margin-bottom: 0.8rem;
    font-size: 1.1rem;
  }

  ul {
    list-style: none;
    padding: 0;
  }

  .title {
    text-align: center;
    margin-bottom: 1rem;
  }

  .logo {
    width: 200px;
    height: auto;
  }

  .social_medias {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 1.5rem;
  }

  .social-icons-list {
    display: flex;
    flex-direction: row;
    gap: 0.8rem;
    margin-top: 5px;
  }

  /* ------------------------- Mobile ------------------------- */
  .footerContainer.mobile {
    margin-inline: auto;
    width: 90%;
  }

  .footerContainer.mobile .detail-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 15px;
  }

  .footerContainer.mobile .contact-details {
    width: 80%;
    margin-inline: auto;
  }

  .footerContainer.mobile .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media screen and (min-width: 1000px) {
    .footerContainer.mobile {
      display: none;
    }
  }

  /* ------------------------- Desktop ------------------------- */

  .footerContainer.desktop {
    display: none;

    padding: 10px;
    flex-direction: row;
    justify-content: center;
    gap: 3rem 6rem;
    flex-wrap: wrap;
  }

  .footerContainer.desktop > * {
    width: 220px;
    min-width: 200px;
  }

  .col1 p {
    text-wrap: wrap;
    min-width: 250px;
  }

  .cats-list li {
    margin-bottom: 0.2rem;
  }

  .payments-list {
    display: flex;
    gap: 0.8rem;
  }

  .col4 {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: flex-start;
    justify-content: flex-start;
  }

  @media screen and (min-width: 1000px) {
    .footerContainer.desktop {
      display: flex;
    }
  }
</style>

<style is:global>
  /* Achicar redes sociales globales del footer */
  .social-icons-list svg, .payments-list svg {
    width: 22px;
    height: 22px;
  }
</style>
