{
  "name": "template-static-ecommerce",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev --host",
    "build": "astro build",
    "build:with-sync": "pnpm run providers:sync && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "scrap": "node src/utils/fetch_productos.js",
    "providers:sync": "pnpm --dir ../webScrappingTool exec ts-node --prefer-ts-exts src/index.ts",
    "images:remove-bg:boots": "node scripts/removeBootBackgrounds.mjs",
    "db:migrate": "node scripts/migrateToSupabase.mjs",
    "deploy": "astro build && rm -rf dist-deploy && mkdir -p dist-deploy && rsync -a --delete dist/ dist-deploy/ && echo '_worker.js' > dist-deploy/.assetsignore && wrangler deploy ./dist-deploy/_worker.js/index.js --assets ./dist-deploy",
    "cf:preview": "astro build && rm -rf dist-deploy && mkdir -p dist-deploy && rsync -a --delete dist/ dist-deploy/ && echo '_worker.js' > dist-deploy/.assetsignore && wrangler dev ./dist-deploy/_worker.js/index.js --assets ./dist-deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/react": "^4.4.2",
    "@nanostores/persistent": "^1.3.4",
    "@supabase/supabase-js": "^2.108.2",
    "astro": "^5.18.1",
    "astro-icon": "1.1.5",
    "astro-navbar": "2.3.9",
    "dompurify": "^3.3.0",
    "fuse.js": "^7.1.0",
    "json2csv": "6.0.0-alpha.2",
    "nanostores": "^1.3.0",
    "nodemailer": "^6.9.4",
    "papaparse": "5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "0.34.2",
    "string-similarity-js": "2.1.4"
  },
  "devDependencies": {
    "@types/papaparse": "5.3.16",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "wrangler": "^4.100.0"
  }
}
